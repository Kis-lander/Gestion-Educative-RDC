              <option value="everyone" {{ privacy.emailVisibility === 'everyone' ? 'selected' : '' }}>
                Tout le monde
              </option>
              <option value="school" {{ privacy.emailVisibility === 'school' ? 'selected' : '' }}>
                Mon école uniquement
