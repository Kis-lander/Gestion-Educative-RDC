            <i class="fas fa-download mr-2"></i>Télécharger mes données
      </button>
          <button
            onclick="deleteMyData()"
            class="w-full px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700"
          >
            <i class="fas fa-trash-alt mr-2"></i>Supprimer toutes mes données
      </button>
          <p class="text-xs text-gray-400 mt-2">
            Cette action est irréversible
          </p>
        </div>
      </div>
    </div>

    <!-- Blocage utilisateur -->
    <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
      <h3 class="font-semibold text-lg border-b pb-2 mb-4">
        Utilisateurs bloqués
      </h3>

      <div class="flex gap-2 mb-4">
        <input
          type="text"
          id="blockUserInput"
          placeholder="Email ou nom d'utilisateur"
          class="flex-1 px-3 py-2 border rounded-lg"
        />
        <button onclick="blockUser()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
          Bloquer
    </button>
      </div>

      <div class="space-y-2" id="blockedList">
        @each(blocked in blockedUsers)
          <div class="flex justify-between items-center p-2 border-b">
            <div>
              <p class="font-medium">
                {{ blocked.name }}
              </p>
              <p class="text-xs text-gray-500">
                {{ blocked.email }}
              </p>
            </div>
            <button onclick="unblockUser('{{ blocked.id }}')" class="text-green-600 text-sm hover:underline">
              Débloquer
      </button>
          </div>
          @else
          <p class="text-gray-500 text-center py-4">
            Aucun utilisateur bloqué
          </p>
        @end
      </div>
    </div>

    <script>
      function saveVisibility() {
        const visibility = {
          profile: document.getElementById("profileVisibility").value,
          email: document.getElementById("emailVisibility").value,
          phone: document.getElementById("phoneVisibility").value,
          dataCollection: document.getElementById("dataCollection")?.checked,
          activityTracking: document.getElementById("activityTracking")?.checked
        };
        fetch("/api/settings/privacy/visibility", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          },
          body: JSON.stringify(visibility)
        }).then(res => res.json()).then(data => {
          if (data.success) alert("Paramètres enregistrés"); else alert("Erreur: " + data.message);
        });
      }

      function downloadMyData() {
        window.location.href = "/api/settings/privacy/export-data";
      }

      function deleteMyData() {
        if (confirm("⚠️ Supprimer TOUTES vos données personnelles ? Cette action est irréversible.")) {
          fetch("/api/settings/privacy/delete-data", {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) window.location.href = "/login"; else alert("Erreur: " + data.message);
          });
        }
      }

      async function blockUser() {
        const identifier = document.getElementById("blockUserInput").value;
        if (!identifier) return;
        const res = await fetch("/api/settings/privacy/block", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          },
          body: JSON.stringify({
            identifier: identifier
          })
        });
        const data = await res.json();
        if (data.success) location.reload(); else alert("Erreur: " + data.message);
      }

      async function unblockUser(userId) {
        const res = await fetch(`/api/settings/privacy/unblock/${userId}`, {
          method: "DELETE",
          headers: {
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          }
        });
        const data = await res.json();
        if (data.success) location.reload(); else alert("Erreur: " + data.message);
      }
    </script>
  @endsection
  
