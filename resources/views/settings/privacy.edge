            <label class="block text-gray-700 dark:text-gray-300 mb-2">Mon téléphone est visible par</label>
            <select id="phoneVisibility" class="w-full px-3 py-2 border rounded-lg">
              <option value="everyone" {{ privacy.phoneVisibility === 'everyone' ? 'selected' : '' }}>
                Tout le monde
              </option>
              <option value="school" {{ privacy.phoneVisibility === 'school' ? 'selected' : '' }}>
