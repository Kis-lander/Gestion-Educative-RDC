                <div class="flex flex-wrap gap-3 mt-1 text-xs text-gray-500">
                  <span>                    <i class="fas fa-book mr-1"></i>{{ question.subjectName }}</span>
                  <span>                    <i class="fas fa-calendar mr-1"></i>{{ question.createdAt }}</span>
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-2 line-clamp-2">
                  {{ question.content }}
                </p>
              </div>
              <div class="text-right text-xs text-gray-400">
                <div class="mb-1">
                  <i class="fas fa-comment mr-1"></i>{{ question.repliesCount || 0 }} réponses
                </div>
                <div>
                  <i class="fas fa-eye mr-1"></i>{{ question.views || 0 }} vues
                </div>
                @if(question.lastReplyAt)
                  <div class="mt-1">
                    Dernière réponse: {{ question.lastReplyAt }}
                  </div>
                @endif
              </div>
            </div>
