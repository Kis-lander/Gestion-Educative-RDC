        </a>
            </div>
          </div>
        @end
      </div>

      @include('partials/pagination', { pagination: pagination, url: '/student/forum/my-questions' })
    </div>

    <script>
      function viewQuestion(questionId) {
        window.location.href = `/student/forum/topic/${questionId}`;
      }

      async function markAsResolved(questionId) {
        event.stopPropagation();
        if (confirm("Marquer cette question comme résolue ?")) {
          const res = await fetch(`/api/student/forum/topic/${questionId}/resolve`, {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          if (data.success) {
            location.reload();
          } else {
            alert("Erreur: " + data.message);
          }
        }
      }
    </script>
  @endsection
  
