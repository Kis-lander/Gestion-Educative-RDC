              <button
                onclick="event.stopPropagation();viewQuestion('{{ question.id }}')"
                class="text-primary text-sm hover:underline"
              >
                <i class="fas fa-eye mr-1"></i>Voir
        </button>
              @if(!question.hasAnswer && !question.isLocked)
                <button
                  onclick="event.stopPropagation();markAsResolved('{{ question.id }}')"
                  class="text-green-600 text-sm hover:underline"
                >
                  <i class="fas fa-check-circle mr-1"></i>Marquer résolu
        </button>
