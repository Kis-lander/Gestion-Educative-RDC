        @each(question in myQuestions)
          <div
            class="p-4 hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer"
            onclick="window.location.href='/student/forum/topic/{{ question.id }}'"
          >
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <h3 class="font-bold text-gray-800 dark:text-white">
                    {{ question.title }}
                  </h3>
                  @if(question.isLocked)
                    <span class="text-xs bg-gray-100 text-gray-800 px-2 py-0.5 rounded">                      <i class="fas fa-lock mr-1"></i>Verrouillé</span>
                  @endif
                  @if(question.hasAnswer)
                    <span class="text-xs bg-green-100 text-green-800 px-2 py-0.5 rounded">                      <i class="fas fa-check-circle mr-1"></i>Répondu</span>
                  @endif
