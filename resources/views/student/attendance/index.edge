    <script>
      let currentMonth = new Date();

      let attendanceChart;

      let calendarData = {};

      async function loadAttendanceData() {
        const childId = {{ student.id }};
        const period = document.getElementById("periodSelect").value;
        const year = document.getElementById("yearSelect").value;
        const res = await fetch(`/api/student/attendance?period=${period}&year=${year}&month=${currentMonth.getMonth() + 1}`);
        const data = await res.json();
        // Mettre Ã  jour les stats
        document.querySelector(".bg-green-500 .text-3xl").textContent = `${data.stats.presentRate}%`;
        document.querySelector(".bg-red-500 .text-3xl").textContent = data.stats.absentCount;
        document.querySelector(".bg-yellow-500 .text-3xl").textContent = data.stats.lateCount;
        document.querySelector(".bg-blue-500 .text-3xl").textContent = data.stats.totalDays;
        calendarData = data.calendarData || {};
        renderCalendar();
        renderChart(data.chartLabels, data.chartValues);
        renderTable(data.attendanceRecords);
      }

      function renderCalendar() {
        const monthNames = [ "Janvier", "FÃ©vrier", "Mars", "Avril", "Mai", "Juin", "Juillet", "AoÃ»t", "Septembre", "Octobre", "Novembre", "DÃ©cembre" ];
        document.getElementById("calendarMonth").textContent = `${monthNames[currentMonth.getMonth()]} ${currentMonth.getFullYear()}`;
        const firstDay = new Date(currentMonth.getFullYear(), currentMonth.getMonth(), 1);
        const lastDay = new Date(currentMonth.getFullYear(), currentMonth.getMonth() + 1, 0);
        const startDayOfWeek = firstDay.getDay();
        const daysInMonth = lastDay.getDate();
        const calendarGrid = document.getElementById("calendarGrid");
        calendarGrid.innerHTML = "";
        // Jours vides
        for (let i = 0; i < startDayOfWeek; i++) {
          const emptyDiv = document.createElement("div");
          emptyDiv.className = "p-2 bg-gray-50 dark:bg-gray-700 rounded min-h-[80px]";
          calendarGrid.appendChild(emptyDiv);
        }
        // Jours du mois
        for (let day = 1; day <= daysInMonth; day++) {
          const dateStr = `${currentMonth.getFullYear()}-${String(currentMonth.getMonth() + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
          const data = calendarData[dateStr] || {
            status: null
          };
          const isToday = new Date().toDateString() === new Date(currentMonth.getFullYear(), currentMonth.getMonth(), day).toDateString();
          const dayDiv = document.createElement("div");
          dayDiv.className = `p-2 rounded min-h-[80px] ${isToday ? "ring-2 ring-primary" : ""} ${data.status === "present" ? "bg-green-50 dark:bg-green-900/20 border border-green-500" : data.status === "absent" ? "bg-red-50 dark:bg-red-900/20 border border-red-500" : data.status === "late" ? "bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-500" : data.status === "excused" ? "bg-blue-50 dark:bg-blue-900/20 border border-blue-500" : "bg-gray-50 dark:bg-gray-700"}`;
          dayDiv.innerHTML = `
                  <div class="text-sm font-bold ${isToday ? "text-primary" : ""}">${day}</div>
                  ${data.status ? `<div class="text-xs mt-1 text-center">
                    <i class="fas ${data.status === "present" ? "fa-check-circle text-green-500" : data.status === "absent" ? "fa-times-circle text-red-500" : data.status === "late" ? "fa-clock text-yellow-500" : "fa-check text-blue-500"}"></i>
                  </div>` : ""}
                  ${data.status ? `<div class="text-xs text-center mt-1">${data.status === "present" ? "PrÃ©sent" : data.status === "absent" ? "Absent" : data.status === "late" ? "Retard" : "ExcusÃ©"}</div>` : ""}
                `;
          calendarGrid.appendChild(dayDiv);
        }
      }

      function renderChart(labels, values) {
        const ctx = document.getElementById("attendanceChart").getContext("2d");
        if (attendanceChart) attendanceChart.destroy();
        attendanceChart = new Chart(ctx, {
          type: "line",
          data: {
            labels: labels,
            datasets: [ {
              label: "PrÃ©sences (%)",
              data: values.present,
              borderColor: "#16a34a",
              backgroundColor: "rgba(22, 163, 74, 0.1)",
              fill: true,
              tension: .4
            }, {
              label: "Absences (%)",
              data: values.absent,
              borderColor: "#dc2626",
              backgroundColor: "rgba(220, 38, 38, 0.1)",
              fill: true,
              tension: .4
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
              y: {
                max: 100,
                min: 0,
                ticks: {
                  stepSize: 20
                }
              }
            }
          }
        });
      }

      function renderTable(records) {
        const tbody = document.getElementById("attendanceTableBody");
        if (!tbody) return;
        if (records && records.length > 0) {
          tbody.innerHTML = records.map(record => `
                  <tr class="border-b dark:border-gray-700">
                    <td class="px-4 py-2">{{ formatDate(record.date) }}</td>
                    <td class="px-4 py-2">${record.periodLabel || "JournÃ©e"}</td>
                    <td class="px-4 py-2">
                      <span class="px-2 py-1 rounded-full text-xs
                        ${record.status === "present" ? "bg-green-100 text-green-800" : record.status === "absent" ? "bg-red-100 text-red-800" : record.status === "late" ? "bg-yellow-100 text-yellow-800" : "bg-blue-100 text-blue-800"}">
                        ${record.status === "present" ? "PrÃ©sent" : record.status === "absent" ? "Absent" : record.status === "late" ? "Retard" : "ExcusÃ©"}
                      </span>
                    </td>
                    <td class="px-4 py-2">${record.reason || "-"}</td>
                    <td class="px-4 py-2 text-center">
                      ${record.status !== "present" ? record.justified ? '<span class="text-green-600"><i class="fas fa-check-circle"></i> JustifiÃ©e</span>' : record.status === "absent" ? '<span class="text-red-600"><i class="fas fa-clock"></i> Non justifiÃ©e</span>' : "-" : "-"}
                    </td>
                  </tr>
                `).join("");
        } else {
          tbody.innerHTML = '<tr><td colspan="5" class="text-center py-8 text-gray-500">Aucun enregistrement pour cette pÃ©riode</td></tr>';
        }
      }

      function previousMonth() {
        currentMonth.setMonth(currentMonth.getMonth() - 1);
        loadAttendanceData();
      }

      function nextMonth() {
        currentMonth.setMonth(currentMonth.getMonth() + 1);
        loadAttendanceData();
      }

      function exportAttendance() {
        const period = document.getElementById("periodSelect").value;
        const year = document.getElementById("yearSelect").value;
        window.location.href = `/api/student/attendance/export?period=${period}&year=${year}`;
      }

      document.getElementById("applyFilters")?.addEventListener("click", () => {
        currentMonth = new Date();
        loadAttendanceData();
      });

      loadAttendanceData();
    </script>
  @endsection
  
