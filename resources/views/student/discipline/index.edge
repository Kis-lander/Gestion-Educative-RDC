          <tbody>
            @each(incident in incidents)
              <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-2">
                  {{ formatDate(incident.date) }}
                </td>
                <td class="px-4 py-2">
                  <span
                    class="px-2 py-1 rounded-full text-xs 
              {{ incident.type === 'absence' ? 'bg-blue-100 text-blue-800' : 
                 (incident.type === 'late' ? 'bg-yellow-100 text-yellow-800' : 
                 (incident.type === 'misconduct' ? 'bg-purple-100 text-purple-800' : 
                 (incident.type === 'violence' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800'))) }}"
                  >
                    {{ incident.typeLabel }}
            </span>
                </td>
                <td class="px-4 py-2">
                  <span
                    class="px-2 py-1 rounded-full text-xs
              {{ incident.severity === 'minor' ? 'bg-green-100 text-green-800' : 
                 (incident.severity === 'moderate' ? 'bg-yellow-100 text-yellow-800' : 
                 (incident.severity === 'major' ? 'bg-orange-100 text-orange-800' : 'bg-red-100 text-red-800')) }}"
                  >
                    {{ incident.severityLabel }}
            </span>
                </td>
                <td class="px-4 py-2 max-w-xs">
                  {{ incident.description }}
                </td>
                <td class="px-4 py-2">
                  @if(incident.sanction && incident.sanction !== 'none')
                    <span class="font-medium text-red-600">{{ incident.sanctionLabel }}</span>
                  @else
                    <span class="text-gray-400">-</span>
                  @endif
                </td>
                <td class="px-4 py-2 text-center">
                  <button onclick="viewDetails('{{ incident.id }}')" class="text-primary hover:underline text-sm">
                    <i class="fas fa-eye"></i>
                  </button>
                </td>
              </tr>
              @else
              <tr>
                <td colspan="6" class="text-center py-12 text-gray-500">
                  <i class="fas fa-check-circle text-4xl mb-2 block text-green-500"></i>
                  Aucun incident disciplinaire enregistré
                  <p class="text-sm mt-1">
                    Félicitations ! Vous avez un comportement exemplaire.
                  </p>
                </td>
              </tr>
            @end
          </tbody>
        </table>
      </div>
      @include('partials/pagination')
    </div>

    <script>
      let incidentsChart;

      function renderChart() {
        const ctx = document.getElementById("incidentsChart").getContext("2d");
        incidentsChart = new Chart(ctx, {
          type: "line",
          data: {
            labels: {{ chartLabels|json_encode|raw }},
            datasets: [ {
              label: "Nombre d'incidents",
              data: {{ chartValues|json_encode|raw }},
              borderColor: "#dc2626",
              backgroundColor: "rgba(220, 38, 38, 0.1)",
              fill: true,
              tension: .4
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
              y: {
                beginAtZero: true,
                stepSize: 1,
                precision: 0
              }
            }
          }
        });
      }

      function viewDetails(incidentId) {
        window.location.href = `/student/discipline/details/${incidentId}`;
      }

      renderChart();
    </script>
  @endsection
  
