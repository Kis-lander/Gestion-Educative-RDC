    <script>
      const filterType = document.getElementById("filterType");

      const filterTerm = document.getElementById("filterTerm");

      const filterYear = document.getElementById("filterYear");

      const filterStatus = document.getElementById("filterStatus");

      const applyBtn = document.getElementById("applyFilters");

      const resetBtn = document.getElementById("resetFilters");

      applyBtn.addEventListener("click", () => {
        const params = new URLSearchParams();
        if (filterType.value) params.set("type", filterType.value);
        if (filterTerm.value) params.set("term", filterTerm.value);
        if (filterYear.value) params.set("year", filterYear.value);
        if (filterStatus.value) params.set("status", filterStatus.value);
        window.location.href = `/financial/fees?${params.toString()}`;
      });

      resetBtn.addEventListener("click", () => {
        window.location.href = "/financial/fees";
      });

      function toggleStatus(feeId, currentStatus) {
        const newStatus = currentStatus === "active" ? "inactive" : "active";
        if (confirm(`${newStatus === "active" ? "Activer" : "DÃ©sactiver"} ce frais ?`)) {
          fetch(`/financial/fees/${feeId}/toggle-status`, {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) location.reload(); else alert("Erreur: " + data.message);
          });
        }
      }

      function deleteFee(feeId) {
        if (confirm("Supprimer dÃ©finitivement ce frais ? Cette action est irrÃ©versible.")) {
          fetch(`/financial/fees/${feeId}`, {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) location.reload(); else alert("Erreur: " + data.message);
          });
        }
      }

      function exportFees() {
        const params = new URLSearchParams();
        if (filterType.value) params.set("type", filterType.value);
        if (filterTerm.value) params.set("term", filterTerm.value);
        if (filterYear.value) params.set("year", filterYear.value);
        window.location.href = `/api/fees/export?${params.toString()}`;
      }
    </script>
  @endsection
  
