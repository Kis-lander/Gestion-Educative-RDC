    <!-- Modal Ã©dition tarifs classe -->
    <div id="editFeesModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full p-6">
        <div class="flex justify-between items-center mb-4">
          <h3 class="font-bold text-lg">
            Modifier tarifs - <span id="modalClassName"></span>
          </h3>
          <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600">
            <i class="fas fa-times"></i>
          </button>
        </div>
        <form id="editFeesForm" method="POST">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
          <input type="hidden" name="_method" value="PUT" />

          <div class="space-y-3">
            <div>
              <label class="block text-gray-600 text-sm mb-1">Inscription</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2">$</span>
                <input
                  type="number"
                  name="inscription"
                  id="inscriptionInput"
                  step="0.01"
                  class="w-full pl-8 pr-3 py-2 border rounded-lg"
                />
              </div>
            </div>
            <div>
              <label class="block text-gray-600 text-sm mb-1">Minerval / trimestre</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2">$</span>
                <input
                  type="number"
                  name="minerval"
                  id="minervalInput"
                  step="0.01"
                  class="w-full pl-8 pr-3 py-2 border rounded-lg"
                />
              </div>
            </div>
            <div>
              <label class="block text-gray-600 text-sm mb-1">Assurance</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2">$</span>
                <input
                  type="number"
                  name="assurance"
                  id="assuranceInput"
                  step="0.01"
                  class="w-full pl-8 pr-3 py-2 border rounded-lg"
                />
              </div>
            </div>
            <div>
              <label class="block text-gray-600 text-sm mb-1">Transport</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2">$</span>
                <input
                  type="number"
                  name="transport"
                  id="transportInput"
                  step="0.01"
                  class="w-full pl-8 pr-3 py-2 border rounded-lg"
                />
              </div>
            </div>
          </div>

          <div class="flex gap-3 mt-6">
            <button type="submit" class="flex-1 px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700">
              Enregistrer
        </button>
            <button type="button" onclick="closeModal()" class="flex-1 px-4 py-2 border rounded-lg hover:bg-gray-50">
              Annuler
        </button>
          </div>
        </form>
      </div>
    </div>

    <script>
      let levelChart, typeChart;

      function renderCharts() {
        const levelCtx = document.getElementById("levelChart").getContext("2d");
        levelChart = new Chart(levelCtx, {
          type: "bar",
          data: {
            labels: {{ levelLabels|json_encode|raw }},
            datasets: [ {
              label: "Inscription",
              data: {{ levelInscription|json_encode|raw }},
              backgroundColor: "#2563eb"
            }, {
              label: "Minerval",
              data: {{ levelMinerval|json_encode|raw }},
              backgroundColor: "#16a34a"
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true
          }
        });
        const typeCtx = document.getElementById("typeChart").getContext("2d");
        typeChart = new Chart(typeCtx, {
          type: "pie",
          data: {
            labels: {{ feeTypeLabels|json_encode|raw }},
            datasets: [ {
              data: {{ feeTypeValues|json_encode|raw }},
              backgroundColor: [ "#2563eb", "#16a34a", "#f59e0b", "#dc2626", "#8b5cf6" ]
            } ]
          },
          options: {
            responsive: true
          }
        });
      }

      let currentClassId = null;

      function editClassFees(classId) {
        currentClassId = classId;
        const row = event.target.closest("tr");
        const values = {
          inscription: row.cells[1]?.innerText.replace(/[^0-9.-]/g, "") || 0,
          minerval: row.cells[2]?.innerText.replace(/[^0-9.-]/g, "") || 0,
          assurance: row.cells[3]?.innerText.replace(/[^0-9.-]/g, "") || 0,
          transport: row.cells[4]?.innerText.replace(/[^0-9.-]/g, "") || 0
        };
        document.getElementById("modalClassName").textContent = row.cells[0]?.innerText || "";
        document.getElementById("inscriptionInput").value = values.inscription;
        document.getElementById("minervalInput").value = values.minerval;
        document.getElementById("assuranceInput").value = values.assurance;
        document.getElementById("transportInput").value = values.transport;
        const modal = document.getElementById("editFeesModal");
        modal.classList.remove("hidden");
        modal.classList.add("flex");
      }

      function closeModal() {
        const modal = document.getElementById("editFeesModal");
        modal.classList.add("hidden");
        modal.classList.remove("flex");
      }

      document.getElementById("editFeesForm")?.addEventListener("submit", async e => {
        e.preventDefault();
        const formData = new FormData(e.target);
        formData.append("classId", currentClassId);
        const res = await fetch("/api/fees/class-structure", {
          method: "POST",
          headers: {
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          },
          body: formData
        });
        const data = await res.json();
        if (data.success) {
          location.reload();
        } else {
          alert("Erreur: " + data.message);
        }
      });

      function exportStructure() {
        const level = document.getElementById("levelFilter").value;
        const year = document.getElementById("yearFilter").value;
        window.location.href = `/api/fees/structure/export?level=${level}&year=${year}`;
      }

      document.getElementById("applyFilters")?.addEventListener("click", () => {
        const level = document.getElementById("levelFilter").value;
        const year = document.getElementById("yearFilter").value;
        const type = document.getElementById("typeFilter").value;
        window.location.href = `/financial/fees/structure?level=${level}&year=${year}&type=${type}`;
      });

      renderCharts();
    </script>
  @endsection
  
