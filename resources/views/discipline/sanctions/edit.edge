      </div>
    </div>

    <script>
      function deleteSanction() {
        if (confirm("Supprimer définitivement cette sanction ? Cette action est irréversible.")) {
          fetch("/discipline/sanctions/{{ sanction.id }}", {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) window.location.href = "/discipline/sanctions"; else alert("Erreur: " + data.message);
          });
        }
      }
    </script>
  @endsection
  
