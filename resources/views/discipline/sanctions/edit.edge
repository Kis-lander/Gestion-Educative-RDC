                  <input
                    type="date"
                    name="startDate"
                    value="{{ sanction.startDate }}"
                    class="w-full px-3 py-2 border rounded-lg"
                  />
                </div>
                <div>
                  <label class="block text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
                  <input
                    type="date"
                    name="endDate"
                    value="{{ sanction.endDate }}"
                    class="w-full px-3 py-2 border rounded-lg"
                  />
                </div>
              </div>
              <div x-show="sanctionType === 'community_service'">
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Nature du travail</label>
                <input
                  type="text"
                  name="workNature"
                  value="{{ sanction.workNature || '' }}"
                  class="w-full px-3 py-2 border rounded-lg"
                />
              </div>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Détails / Observations</label>
