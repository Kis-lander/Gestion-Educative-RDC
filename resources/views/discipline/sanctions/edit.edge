          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Appliquée par</span>
              <span>{{ sanction.appliedByName }}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-500">Date d'application</span>
              <span>{{ formatDate(sanction.appliedDate) }}</span>
            </div>
