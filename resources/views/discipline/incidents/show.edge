    <!-- Timeline des incidents précédents -->
    <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
      <div class="px-4 py-3 border-b dark:border-gray-700">
        <h3 class="font-semibold">
          Antécédents de l'élève
        </h3>
      </div>
      <div class="divide-y dark:divide-gray-700 max-h-64 overflow-y-auto">
        @each(prevIncident in previousIncidents)
          <div class="p-3 hover:bg-gray-50">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-medium">
                  {{ prevIncident.typeLabel }}
                </p>
                <p class="text-xs text-gray-500">
                  {{ formatDate(prevIncident.date) }}
                </p>
                <p class="text-sm text-gray-600 mt-1">
                  {{ prevIncident.description }}
                </p>
              </div>
              <div class="text-right">
                <span
                  class="px-2 py-1 rounded-full text-xs
            {{ prevIncident.severity === 'minor' ? 'bg-green-100 text-green-800' : 
               (prevIncident.severity === 'moderate' ? 'bg-yellow-100 text-yellow-800' : 
               (prevIncident.severity === 'major' ? 'bg-orange-100 text-orange-800' : 'bg-red-100 text-red-800')) }}"
                >
                  {{ prevIncident.severityLabel }}
          </span>
              </div>
