          <div class="p-6 text-center text-gray-500">
            Aucun antécédent
          </div>
        @end
      </div>
    </div>

    <script>
      function printIncident() {
        window.print();
      }

      function notifyParent() {
        if (confirm("Notifier les parents de cet incident ?")) {
          fetch("/discipline/incidents/{{ incident.id }}/notify-parent", {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) location.reload(); else alert("Erreur: " + data.message);
          });
        }
      }
    </script>

    <style>
      @media print {
        .sidebar,
        header,
        footer,
        button,
        .actions,
        .no-print {
          display: none !important;
        }
      }
    </style>
