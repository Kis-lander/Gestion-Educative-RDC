            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Description</label>
              <textarea name="description" rows="4" class="w-full px-3 py-2 border rounded-lg">{{ incident.description }}</textarea>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Action prise</label>
              <textarea name="actionTaken" rows="3" class="w-full px-3 py-2 border rounded-lg">{{ incident.actionTaken || '' }}</textarea>
            </div>

            <div>
              <label class="flex items-center gap-3 cursor-pointer">
