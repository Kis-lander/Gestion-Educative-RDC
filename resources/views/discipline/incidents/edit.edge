          </h3>
          @if(incident.sanction && incident.sanction !== 'none')
            <p class="text-sm">
              Sanction: <strong class="text-red-600">{{ incident.sanctionLabel }}</strong>
            </p>
          @else
            <p class="text-sm text-gray-500">
              Aucune sanction appliquée
            </p>
          @endif
          <div class="mt-2">
            <a
              href="/discipline/sanctions/apply?incident_id={{ incident.id }}"
              class="text-primary text-sm hover:underline"
            >
              @if(incident.sanction && incident.sanction !== 'none')
                Modifier la sanction
              @else
                Appliquer une sanction
              @endif
            </a>
          </div>
        </div>
      </div>
    </div>

    <script>
      function deleteIncident() {
        if (confirm("Supprimer définitivement cet incident ? Cette action est irréversible.")) {
          fetch("/discipline/incidents/{{ incident.id }}", {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) window.location.href = "/discipline/incidents"; else alert("Erreur: " + data.message);
          });
        }
      }
    </script>
  @endsection
  
