                  Majeure
                </option>
                <option value="critical" {{ incident.severity === 'critical' ? 'selected' : '' }}>
                  Critique
                </option>
              </select>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Date de l'incident</label>
              <input
                type="date"
                name="incidentDate"
                value="{{ incident.date }}"
                class="w-full px-3 py-2 border rounded-lg"
              />
