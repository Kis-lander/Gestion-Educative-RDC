    <!-- Appréciation finale -->
    <div class="mt-6 bg-blue-50 dark:bg-blue-900/20 rounded-xl p-4">
      <div class="flex items-start gap-3">
        <i class="fas fa-star text-yellow-500 text-xl"></i>
        <div>
          <h4 class="font-semibold">
            Appréciation générale
          </h4>
          <p class="text-sm text-gray-700 dark:text-gray-300">
            @if(stats.totalIncidents === 0)
              Félicitations ! Cet élève a un comportement exemplaire et mérite d'être valorisé.
            @elseif(stats.totalIncidents <= 2)
              Bon comportement général. Quelques incidents mineurs à surveiller.
            @elseif(stats.totalIncidents <= 5)
              Comportement à améliorer. Un suivi régulier est recommandé.
            @else
              Comportement préoccupant. Des mesures disciplinaires sont nécessaires.
            @endif
          </p>
        </div>
      </div>
    </div>

    <script>
      let trendChart, typeChart;

      function renderCharts() {
        // Graphique tendance
        const trendCtx = document.getElementById("studentTrendChart").getContext("2d");
        trendChart = new Chart(trendCtx, {
          type: "line",
          data: {
            labels: {{ trendLabels|json_encode|raw }},
            datasets: [ {
              label: "Nombre d'incidents",
              data: {{ trendValues|json_encode|raw }},
              borderColor: "#dc2626",
              fill: true,
              tension: .4
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true
          }
        });
        // Graphique par type
        const typeCtx = document.getElementById("studentTypeChart").getContext("2d");
        typeChart = new Chart(typeCtx, {
          type: "doughnut",
          data: {
            labels: {{ typeLabels|json_encode|raw }},
            datasets: [ {
              data: {{ typeValues|json_encode|raw }},
              backgroundColor: [ "#2563eb", "#f59e0b", "#8b5cf6", "#dc2626", "#6b7280" ]
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true
          }
        });
      }

      function printReport() {
        window.print();
      }

      function downloadPDF() {
        window.location.href = `/api/discipline/reports/student/{{ student.id }}/pdf`;
      }

      renderCharts();
    </script>
  @endsection
  
