    <!-- Détail des incidents -->
    <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
      <div class="px-4 py-3 border-b dark:border-gray-700">
        <h3 class="font-semibold">
          Détail des incidents
        </h3>
      </div>
      <div class="table-responsive">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-4 py-2">
                Date
              </th>
              <th class="px-4 py-2">
                Type
              </th>
              <th class="px-4 py-2">
                Gravité
              </th>
              <th class="px-4 py-2">
                Description
              </th>
              <th class="px-4 py-2">
                Sanction
              </th>
              <th class="px-4 py-2">
                Statut
              </th>
            </tr>
          </thead>
          <tbody>
            @each(incident in incidents)
              <tr class="border-b dark:border-gray-700">
                <td class="px-4 py-2">
                  {{ formatDate(incident.date) }}
                </td>
                <td class="px-4 py-2">
                  {{ incident.typeLabel }}
                </td>
                <td class="px-4 py-2">
                  {{ incident.severityLabel }}
                </td>
                <td class="px-4 py-2">
                  {{ incident.description }}
                </td>
                <td class="px-4 py-2">
                  {{ incident.sanction || '-' }}
                </td>
                <td class="px-4 py-2">
                  <span
                    class="px-2 py-1 rounded-full text-xs
              {{ incident.status === 'pending' ? 'bg-yellow-100 text-yellow-800' : 
                 (incident.status === 'resolved' ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800') }}"
                  >
                    {{ incident.status === 'pending' ? 'En attente' : (incident.status === 'resolved' ? 'Résolu' : 'En appel') }}
            </span>
                </td>
              </tr>
            @end
          </tbody>
        </table>
      </div>
    </div>

