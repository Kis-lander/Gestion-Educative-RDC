      <button onclick="startInspection()" class="block mx-auto mt-3 text-primary hover:underline">Démarrer une inspection</button>
          </div>
        @end
      </div>
    </div>

    <script>
      function generateFullReport() {
        window.open(`/inspection/reports/school/{{ school.id }}?full=1`, "_blank");
      }

      function sendMessageToDirector() {
        window.location.href = `/communication/messages/send?receiver_id={{ director?.id }}`;
      }

      function startInspection() {
        window.location.href = `/inspection/schools/{{ school.id }}/inspect`;
      }
    </script>
  @endsection
  
