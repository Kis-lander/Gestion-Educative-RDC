        <h3 class="font-semibold">
          Historique des inspections
        </h3>
      </div>
      <div class="divide-y dark:divide-gray-700">
        @each(inspection in inspections)
          <div class="p-4">
            <div class="flex justify-between items-start">
              <div>
                <p class="font-medium">
                  {{ inspection.date }} - {{ inspection.inspector }}
                </p>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                  {{ inspection.report }}
                </p>
                @if(inspection.rating)
                  <div class="flex items-center gap-1 mt-2">
                    <span class="text-xs text-gray-500">Note:</span>
                    <div class="flex">
                      @for(i = 0; i < 5; i++)
                        <i class=fas fa-star text-xs {{ i < inspection.rating ? 'text-yellow-500' : 'text-gray-300' }}></i>
                      @endfor
                    </div>
                  </div>
                @endif
              </div>
              @if(inspection.recommendations)
                <div class="bg-blue-50 dark:bg-blue-900/20 p-2 rounded text-xs max-w-xs">
                  <p class="font-medium">
                    Recommandations:
                  </p>
                  <p class="text-gray-600">
                    {{ inspection.recommendations }}
                  </p>
                </div>
              @endif
            </div>
          </div>
          @else
          <div class="p-8 text-center text-gray-500">
            <i class="fas fa-clipboard-list text-3xl mb-2 block"></i>
