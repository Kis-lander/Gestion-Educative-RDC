    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
      <div id="credentialsCard" class="xl:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 print:shadow-none">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 border-b pb-5 mb-5">
          <div>
            <p class="text-sm uppercase tracking-wide text-green-600 dark:text-green-400 font-semibold">
              Approbation confirmee
            </p>
