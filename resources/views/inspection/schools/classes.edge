              <th class="px-4 py-3 text-left">Titulaire</th>
            </tr>
          </thead>
          <tbody>
            @each(classObj in classes)
              <tr class="border-b dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-3 font-medium">{{ classObj.name }}</td>
                <td class="px-4 py-3 text-center">{{ classObj.level }} - {{ classObj.gradeLevel }}</td>
                <td class="px-4 py-3 text-center">{{ classObj.academicYear }}</td>
                <td class="px-4 py-3 text-center">
                  {{ classObj.shift === 'morning' ? 'Matin' : (classObj.shift === 'afternoon' ? 'Après-midi' : 'Soir') }}
                </td>
                <td class="px-4 py-3 text-center">
                  {{ classObj.currentEnrollment || 0 }}/{{ classObj.maxCapacity || 0 }}
