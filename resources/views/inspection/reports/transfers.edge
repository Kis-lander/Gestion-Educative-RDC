      <h3 class="font-semibold mb-4">
        Flux de transferts entre provinces
      </h3>
      <div class="table-responsive">
        <table class="w-full text-sm" id="flowMatrix">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-3 py-2">
                De / Vers
              </th>
              <th class="px-3 py-2 text-center">
                Kinshasa
              </th>
              <th class="px-3 py-2 text-center">
                Kongo Central
              </th>
              <th class="px-3 py-2 text-center">
                Haut-Katanga
              </th>
              <th class="px-3 py-2 text-center">
                Nord-Kivu
              </th>
              <th class="px-3 py-2 text-center">
