    </div>

    <!-- Liste des transferts -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
      <div class="px-4 py-3 border-b dark:border-gray-700">
        <h3 class="font-semibold">
          Détail des transferts
        </h3>
      </div>
      <div class="table-responsive">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-4 py-2">
                Date
              </th>
              <th class="px-4 py-2">
                Élève
              </th>
              <th class="px-4 py-2">
                École origine
              </th>
              <th class="px-4 py-2">
                École destination
              </th>
              <th class="px-4 py-2 text-center">
                Statut
              </th>
              <th class="px-4 py-2 text-center">
                Délai
              </th>
            </tr>
          </thead>
          <tbody id="transfersList">
          </tbody>
        </table>
      </div>
    </div>

    <script>
      let chart1, chart2;

      async function loadReport() {
        const startDate = document.getElementById("startDate").value;
        const endDate = document.getElementById("endDate").value;
        const province = document.getElementById("province").value;
        const status = document.getElementById("status").value;
        const params = new URLSearchParams();
        if (startDate) params.append("start_date", startDate);
        if (endDate) params.append("end_date", endDate);
        if (province) params.append("province", province);
        if (status) params.append("status", status);
        const res = await fetch(`/api/inspection/reports/transfers?${params.toString()}`);
        const data = await res.json();
        // Indicateurs
        document.getElementById("totalTransfers").textContent = data.summary?.total || 0;
        document.getElementById("completedTransfers").textContent = data.summary?.completed || 0;
        document.getElementById("pendingTransfers").textContent = data.summary?.pending || 0;
        document.getElementById("avgProcessingTime").textContent = data.summary?.avgDays || 0;
        // Graphique tendance
        if (chart1) chart1.destroy();
        const ctx1 = document.getElementById("trendChart").getContext("2d");
        chart1 = new Chart(ctx1, {
          type: "line",
          data: {
            labels: data.trend?.labels || [],
            datasets: [ {
              label: "Nombre de transferts",
              data: data.trend?.values || [],
              borderColor: "#2563eb",
              fill: true,
              tension: .4
            } ]
          },
          options: {
            responsive: true
          }
        });
        // Graphique origines
        if (chart2) chart2.destroy();
        const ctx2 = document.getElementById("originChart").getContext("2d");
        chart2 = new Chart(ctx2, {
          type: "pie",
          data: {
            labels: data.topOrigins?.map(o => o.province) || [],
            datasets: [ {
              data: data.topOrigins?.map(o => o.count) || [],
              backgroundColor: [ "#2563eb", "#16a34a", "#f59e0b", "#dc2626", "#8b5cf6" ]
            } ]
          },
          options: {
            responsive: true
          }
        });
        // Matrice des flux
        if (data.flowMatrix) {
          const provinces = [ "Kinshasa", "Kongo Central", "Haut-Katanga", "Nord-Kivu", "Sud-Kivu" ];
          let matrixHtml = "";
          provinces.forEach(from => {
            matrixHtml += `<tr class="border-b"><td class="px-3 py-2 font-medium">${from}</td>`;
            provinces.forEach(to => {
              const value = data.flowMatrix[from]?.[to] || 0;
              matrixHtml += `<td class="px-3 py-2 text-center ${value > 0 ? "bg-green-50 dark:bg-green-900/20" : ""}">${value || "-"}</td>`;
            });
            matrixHtml += "</tr>";
          });
          document.getElementById("flowMatrixBody").innerHTML = matrixHtml;
        }
        // Liste des transferts
        if (data.transfers && data.transfers.length > 0) {
          document.getElementById("transfersList").innerHTML = data.transfers.map(t => `
                  <tr class="border-b dark:border-gray-700">
                    <td class="px-4 py-2">${formatDate(t.date)}</td>
                    <td class="px-4 py-2">${t.studentName}</td>
                    <td class="px-4 py-2">${t.fromSchool}</td>
                    <td class="px-4 py-2">${t.toSchool}</td>
                    <td class="px-4 py-2 text-center">
                      <span class="px-2 py-0.5 rounded-full text-xs ${t.status === "completed" ? "bg-green-100 text-green-800" : t.status === "pending" ? "bg-yellow-100 text-yellow-800" : "bg-gray-100 text-gray-800"}">
                        ${t.status === "completed" ? "Complété" : t.status === "pending" ? "En attente" : t.status}
                      </span>
                    </td>
                    <td class="px-4 py-2 text-center">${t.processingDays || "-"} j</td>
                  </tr>
                `).join("");
        } else {
          document.getElementById("transfersList").innerHTML = '<tr><td colspan="6" class="text-center py-8">Aucun transfert trouvé</td></tr>';
        }
      }

      function formatDate(date) {
        return new Date(date).toLocaleDateString("fr-FR");
      }

      function exportReport(format) {
        const startDate = document.getElementById("startDate").value;
        const endDate = document.getElementById("endDate").value;
        const province = document.getElementById("province").value;
        const status = document.getElementById("status").value;
        window.location.href = `/api/inspection/reports/transfers/export?format=${format}&start_date=${startDate}&end_date=${endDate}&province=${province}&status=${status}`;
      }

      document.getElementById("applyFilters").addEventListener("click", loadReport);
      // Dates par défaut (3 derniers mois)

      const today = new Date();

      const threeMonthsAgo = new Date();

      threeMonthsAgo.setMonth(today.getMonth() - 3);

      document.getElementById("startDate").value = threeMonthsAgo.toISOString().split("T")[0];

      document.getElementById("endDate").value = today.toISOString().split("T")[0];

      loadReport();
    </script>
  @endsection
  
