          </thead>
          <tbody id="provincesRanking">
          </tbody>
        </table>
      </div>
    </div>

    <script>
      let chart1, chart2;

      async function loadReport() {
        const year = document.getElementById("academicYear").value;
        const term = document.getElementById("term").value;
        const level = document.getElementById("level").value;
        const params = new URLSearchParams({
          year: year,
          term: term
        });
        if (level) params.append("level", level);
        const res = await fetch(`/api/inspection/reports/performance?${params.toString()}`);
        const data = await res.json();
        // Indicateurs
        document.getElementById("avgNational").textContent = data.nationalAverage?.toFixed(1) || "0.0";
        document.getElementById("bestProvince").textContent = data.bestProvince?.name || "-";
        document.getElementById("worstProvince").textContent = data.worstProvince?.name || "-";
        document.getElementById("topSubject").textContent = data.topSubject?.name || "-";
        // Graphique provinces
        if (chart1) chart1.destroy();
        const ctx1 = document.getElementById("provincePerformanceChart").getContext("2d");
        chart1 = new Chart(ctx1, {
          type: "bar",
          data: {
            labels: data.provinces?.map(p => p.name) || [],
            datasets: [ {
              label: "Moyenne /20",
              data: data.provinces?.map(p => p.average) || [],
              backgroundColor: "#2563eb",
              borderRadius: 8
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
              y: {
                max: 20
              }
            }
          }
        });
        // Graphique top Ã©coles
        if (chart2) chart2.destroy();
        const ctx2 = document.getElementById("topSchoolsChart").getContext("2d");
        chart2 = new Chart(ctx2, {
          type: "horizontalBar",
          data: {
            labels: data.topSchools?.map(s => s.name.substring(0, 20)) || [],
            datasets: [ {
              label: "Moyenne /20",
              data: data.topSchools?.map(s => s.average) || [],
              backgroundColor: "#16a34a"
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            indexAxis: "y",
            scales: {
              x: {
                max: 20
              }
            }
          }
        });
        // MatiÃ¨res
        const subjectsHtml = data.subjects?.map(sub => `
                <div>
                  <div class="flex justify-between text-sm mb-1">
                    <span>${sub.name}</span>
                    <span class="font-medium">${sub.average.toFixed(1)}/20</span>
                  </div>
                  <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-${sub.average >= 15 ? "green" : sub.average >= 10 ? "yellow" : "red"}-500 rounded-full h-2" style="width: ${sub.average / 20 * 100}%"></div>
                  </div>
                </div>
              `).join("") || "<p>Aucune donnÃ©e</p>";
        document.getElementById("subjectsPerformance").innerHTML = subjectsHtml;
        // Classement provinces
        const rankingHtml = data.provinces?.map((p, index) => `
                <tr class="border-b dark:border-gray-700">
                  <td class="px-4 py-2 text-center font-bold">${index + 1}</td>
                  <td class="px-4 py-2">${p.name}</td>
                  <td class="px-4 py-2 text-center font-medium ${p.average >= 15 ? "text-green-600" : p.average >= 10 ? "text-yellow-600" : "text-red-600"}">${p.average.toFixed(1)}/20</td>
                  <td class="px-4 py-2 text-center">${p.successRate || 0}%</td>
                  <td class="px-4 py-2 text-center">
                    ${p.trend > 0 ? `<span class="text-green-600"><i class="fas fa-arrow-up"></i> +${p.trend}%</span>` : p.trend < 0 ? `<span class="text-red-600"><i class="fas fa-arrow-down"></i> ${p.trend}%</span>` : "-"}
                  </td>
                </tr>
              `).join("") || '<tr><td colspan="5" class="text-center py-8">Aucune donnÃ©e</td></tr>';
        document.getElementById("provincesRanking").innerHTML = rankingHtml;
      }

      function exportReport(format) {
        const year = document.getElementById("academicYear").value;
        const term = document.getElementById("term").value;
        const level = document.getElementById("level").value;
        window.location.href = `/api/inspection/reports/performance/export?format=${format}&year=${year}&term=${term}&level=${level}`;
      }

      document.getElementById("applyFilters").addEventListener("click", loadReport);

      loadReport();
    </script>
  @endsection
  
