        </form>
      </div>

      <!-- Aperçu et informations école -->
      <div class="space-y-6">
        <!-- Aperçu du message -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6" x-show="preview" x-cloak>
          <h3 class="font-semibold text-lg border-b pb-2 mb-3">
            Aperçu du message
          </h3>
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
              <i class="fas fa-bullhorn"></i>
              <span>Inspection Pédagogique - RDC</span>
            </div>
            <div
              class="font-bold text-gray-800 dark:text-white mb-2"
              x-text="document.querySelector('[name=subject]')?.value || 'Objet'"
            >
            </div>
            <div
              class="text-gray-600 dark:text-gray-400 whitespace-pre-wrap"
              x-text="document.querySelector('[name=content]')?.value || 'Contenu du message...'"
            >
            </div>
          </div>
        </div>

        <!-- Informations école sélectionnée -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
          <h3 class="font-semibold mb-3">
            Informations de l'école
          </h3>
          <div id="schoolInfo" class="text-sm text-gray-500 text-center py-4">
            Sélectionnez une école pour voir ses informations
          </div>
