                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="deputy_discipline_director" x-model="targetRole" class="w-4 h-4" />
                  <span>Directeur de discipline adjoint uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="finance_director" x-model="targetRole" class="w-4 h-4" />
                  <span>Directeur financier uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="secretary" x-model="targetRole" class="w-4 h-4" />
                  <span>Secr&eacute;taire uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="teacher" x-model="targetRole" class="w-4 h-4" />
                  <span>Enseignants uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="parent" x-model="targetRole" class="w-4 h-4" />
                  <span>Parents uniquement</span>
                </label>
              </div>
            </div>

            <div class="mb-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="requireAcknowledgment" x-model="requireAcknowledgment" class="w-4 h-4" />
                <span>Exiger un accusé de réception</span>
              </label>
            </div>

            <div class="flex gap-3">
              <button
                type="button"
                @click="preview = !preview"
                class="px-4 py-2 border rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700"
              >
                <i class="fas fa-eye mr-2"></i>Aperçu
          </button>
              <button
                type="submit"
                :disabled="loading"
                class="flex-1 px-6 py-2 bg-primary text-white rounded-lg hover:bg-blue-700"
              >
                <i x-show="loading" class="fas fa-spinner fa-spin mr-2"></i>
                <span>Envoyer le message</span>
              </button>
            </div>
          </div>
        </form>
      </div>

      <!-- Aperçu et informations école -->
      <div class="space-y-6">
        <!-- Aperçu du message -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6" x-show="preview" x-cloak>
          <h3 class="font-semibold text-lg border-b pb-2 mb-3">
            Aperçu du message
          </h3>
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
            <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
              <i class="fas fa-bullhorn"></i>
              <span>Inspection Pédagogique - RDC</span>
            </div>
            <div
              class="font-bold text-gray-800 dark:text-white mb-2"
              x-text="subject || 'Objet'"
            >
            </div>
            <div
              class="text-gray-600 dark:text-gray-400 whitespace-pre-wrap"
              x-text="content || 'Contenu du message...'"
            >
            </div>
            <div class="mt-3 pt-2 border-t text-xs text-gray-400">
              Ecole: <span x-text="selectedSchoolLabel || 'Aucune ecole selectionnee'"></span>
            </div>
            <div class="mt-2 text-xs text-gray-400">
              Destinataires:
              <span
                x-text="({
                  all: 'Tous les utilisateurs de cette ecole',
                  promoter: 'Promoteur uniquement',
                  preschool_director: 'Directeur de la maternelle uniquement',
                  primary_director: 'Directeur du primaire uniquement',
                  prefect: 'Prefet des etudes uniquement',
                  studies_director: 'Directeur des etudes uniquement',
                  pedagogical_advisor: 'Conseiller pedagogique uniquement',
                  discipline_director: 'Directeur de discipline titulaire uniquement',
                  deputy_discipline_director: 'Directeur de discipline adjoint uniquement',
                  finance_director: 'Directeur financier uniquement',
                  secretary: 'Secretaire uniquement',
                  teacher: 'Enseignants uniquement',
                  parent: 'Parents uniquement'
                }[targetRole] || 'Tous les utilisateurs de cette ecole')"
              ></span>
            </div>
            <div x-show="requireAcknowledgment" class="mt-3 text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded">
              Accuse de reception requis
            </div>
            <div class="mt-4 flex gap-2">
              <button type="button" @click="preview = false; confirmed = false" class="px-4 py-2 border rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">
                Modifier
              </button>
              <button
                type="button"
                @click="confirmed = true; $nextTick(() => $refs.form.requestSubmit())"
                :disabled="loading"
                class="flex-1 px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700"
              >
                <i x-show="loading" class="fas fa-spinner fa-spin mr-2"></i>
                Confirmer l'envoi
              </button>
            </div>
          </div>
        </div>

        <!-- Informations école sélectionnée -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
          <h3 class="font-semibold mb-3">
            Informations de l'école
          </h3>
          <div id="schoolInfo" class="text-sm text-gray-500 text-center py-4">
            Sélectionnez une école pour voir ses informations
          </div>
        </div>

        <!-- Conseils -->
        <div class="bg-green-50 dark:bg-green-900/20 rounded-xl p-4">
          <h3 class="font-semibold mb-2">
            Conseils de communication
          </h3>
          <ul class="text-sm space-y-2">
            <li class="flex gap-2">
              <i class="fas fa-check-circle text-green-500 mt-0.5"></i>
              <span>Soyez clair et concis dans votre message</span>
            </li>
            <li class="flex gap-2">
              <i class="fas fa-check-circle text-green-500 mt-0.5"></i>
              <span>Précisez les dates et délais importants</span>
            </li>
            <li class="flex gap-2">
              <i class="fas fa-check-circle text-green-500 mt-0.5"></i>
              <span>Utilisez le mode "urgent" pour les sujets prioritaires</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Historique des communications avec cette école -->
    <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden">
      <div class="px-4 py-3 border-b dark:border-gray-700">
        <h3 class="font-semibold">
          Historique des communications
        </h3>
      </div>
      <div class="divide-y dark:divide-gray-700 max-h-96 overflow-y-auto" id="historyContainer">
        <div class="p-8 text-center text-gray-500">
          Sélectionnez une école pour voir l'historique des communications
        </div>
      </div>
    </div>

    <script>
      // Charger les informations de l'école
      async function loadSchoolInfo(schoolId) {
        if (!schoolId) {
          document.getElementById("schoolInfo").innerHTML = window.AppTranslations?.translate("Sélectionnez une école pour voir ses informations") || "Sélectionnez une école pour voir ses informations";
          document.getElementById("historyContainer").innerHTML = `
                  <div class="p-8 text-center text-gray-500">
                    ${window.AppTranslations?.translate("Sélectionnez une école pour voir l'historique des communications") || "Sélectionnez une école pour voir l'historique des communications"}
                  </div>
                `;
          return;
        }
        const infoContainer = document.getElementById("schoolInfo");
        infoContainer.innerHTML = `<div class="text-center py-4">${window.AppTranslations?.translate("Chargement...") || "Chargement..."}</div>`;
        const res = await fetch(`/api/schools/${schoolId}/info`);
        if (!res.ok) {
          infoContainer.innerHTML = `<div class="text-red-500 text-center py-4">${window.AppTranslations?.translate("Impossible de charger les informations de cette école") || "Impossible de charger les informations de cette école"}</div>`;
          return;
        }
        const data = await res.json();
        const infoHtml = `
                <div class="space-y-2 text-sm">
                  <div class="flex justify-between">
                    <span class="text-gray-500">${window.AppTranslations?.translate("Nom de l'école") || "Nom de l'école"}</span>
                    <span class="font-medium">${data.name || "-"}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">${window.AppTranslations?.translate("Province") || "Province"}</span>
                    <span>${data.province || "-"}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">${window.AppTranslations?.translate("Promoteur") || "Promoteur"}</span>
                    <span>${data.directorName || "-"}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">${window.AppTranslations?.translate("Email") || "Email"}</span>
                    <span>${data.email || "-"}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">${window.AppTranslations?.translate("Téléphone") || "Téléphone"}</span>
                    <span>${data.phone || "-"}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">${window.AppTranslations?.translate("Statut") || "Statut"}</span>
                    <span class="px-2 py-0.5 rounded-full text-xs ${data.status === "active" ? "bg-green-100 text-green-800" : "bg-yellow-100 text-yellow-800"}">${data.status === "active" ? (window.AppTranslations?.translate("Actif") || "Actif") : (window.AppTranslations?.translate("En attente") || "En attente")}</span>
                  </div>
                </div>
              `;
        infoContainer.innerHTML = infoHtml;
        // Charger l'historique
        loadHistory(schoolId);
      }
      // Charger l'historique des communications

      async function loadHistory(schoolId) {
        const container = document.getElementById("historyContainer");
        container.innerHTML = `<div class="p-8 text-center text-gray-500">${window.AppTranslations?.translate("Chargement de l'historique...") || "Chargement de l'historique..."}</div>`;
        const res = await fetch(`/api/schools/${schoolId}/communications`);
        if (!res.ok) {
          container.innerHTML = `
                  <div class="p-8 text-center text-red-500">
                    ${window.AppTranslations?.translate("Impossible de charger l'historique des communications") || "Impossible de charger l'historique des communications"}
                  </div>
                `;
          return;
        }
        const data = await res.json();
        if (data.communications && data.communications.length > 0) {
          let historyHtml = "";
          for (const comm of data.communications) {
            historyHtml += `
                    <div class="p-4 hover:bg-gray-50 dark:hover:bg-gray-700">
                      <div class="flex justify-between items-start">
                        <div class="flex-1">
                          <div class="flex items-center gap-2">
                            <p class="font-medium">${comm.subject}</p>
                            ${comm.urgent ? `<span class="text-xs bg-red-100 text-red-800 px-2 py-0.5 rounded">${window.AppTranslations?.translate("Urgent") || "Urgent"}</span>` : ""}
                          </div>
                          <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">${(comm.content || "").substring(0, 150)}${(comm.content || "").length > 150 ? "..." : ""}</p>
                          <div class="flex gap-3 mt-2 text-xs text-gray-400">
                            <span><i class="fas fa-calendar mr-1"></i> ${formatDate(comm.createdAt)}</span>
                            <span><i class="fas fa-envelope mr-1"></i> ${window.AppTranslations?.translate("Destinataires") || "Destinataires"}: ${comm.recipientType === "all" ? (window.AppTranslations?.translate("Tous") || "Tous") : comm.recipientType}</span>
                            ${comm.acknowledged ? `<span class="text-green-600"><i class="fas fa-check-circle mr-1"></i> ${window.AppTranslations?.translate("Accusé reçu") || "Accusé reçu"}</span>` : ""}
                          </div>
                        </div>
                        <button onclick="viewCommunication('${comm.id}')" class="text-primary text-sm hover:underline">Détails</button>
                      </div>
                    </div>
                  `;
          }
          container.innerHTML = historyHtml;
        } else {
          container.innerHTML = `
                  <div class="p-8 text-center text-gray-500">
                    <i class="fas fa-history text-3xl mb-2 block"></i>
                    ${window.AppTranslations?.translate("Aucune communication antérieure avec cette école") || "Aucune communication antérieure avec cette école"}
                  </div>
                `;
        }
      }
      // Observer le changement d'école

      document.querySelector("[name=schoolId]").addEventListener("change", e => {
        const schoolId = e.target.value;
        loadSchoolInfo(schoolId);
      });

      const initialSchoolId = document.querySelector("[name=schoolId]")?.value;
      if (initialSchoolId) {
        loadSchoolInfo(initialSchoolId);
      }

      function viewCommunication(id) {
        window.location.href = `/inspection/communications/${id}`;
      }

      function formatDate(date) {
        return new Date(date).toLocaleDateString("fr-FR");
      }
    </script>
  @endsection
  
