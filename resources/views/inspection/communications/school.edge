  @section('content')
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6" x-data="{ loading: false, preview: false, confirmed: false, selectedSchool: null, selectedSchoolLabel: '', subject: '', content: '', targetRole: 'all', requireAcknowledgment: false }">
      <!-- Formulaire de communication -->
      <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
        <form
          x-ref="form"
          method="POST"
          action="/inspection/communications/school"
          @submit.prevent="if (!confirmed) { preview = true; return } loading = true; $el.submit()"
        >
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          <div class="mb-4">
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Sélectionner l'école *</label>
            <select
              name="schoolId"
              required
              class="w-full px-3 py-2 border rounded-lg"
              x-model="selectedSchool"
              @change="selectedSchoolLabel = $event.target.selectedOptions[0]?.text.trim() || ''"
            >
              <option value="">
                -- Choisir une école --
              </option>
              @each(school in schools)
                <option value="{{ school.id }}">
                  {{ school.name }} ({{ school.province }})
                </option>
              @end
            </select>
          </div>

          <div x-show="selectedSchool" x-cloak>
            <div class="mb-4">
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Objet *</label>
              <input
                type="text"
                name="subject"
                x-model="subject"
                required
                class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-primary"
                placeholder="Ex: Prochaine inspection"
              />
            </div>

            <div class="mb-4">
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Contenu du message *</label>
              <textarea
                name="content"
                x-model="content"
                rows="8"
                required
                class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-primary"
                placeholder="Saisissez votre message ici..."
              ></textarea>
            </div>

            <div class="mb-4">
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Destinataires spécifiques (optionnel)</label>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="all" x-model="targetRole" checked class="w-4 h-4" />
                  <span>Tous les utilisateurs de l'école</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="promoter" x-model="targetRole" class="w-4 h-4" />
                  <span>Promoteur uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="preschool_director" x-model="targetRole" class="w-4 h-4" />
                  <span>Directeur de la maternelle uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="primary_director" x-model="targetRole" class="w-4 h-4" />
                  <span>Directeur du primaire uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="prefect" x-model="targetRole" class="w-4 h-4" />
                  <span>Pr&eacute;fet des &eacute;tudes uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="studies_director" x-model="targetRole" class="w-4 h-4" />
                  <span>Directeur des &eacute;tudes uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="pedagogical_advisor" x-model="targetRole" class="w-4 h-4" />
                  <span>Conseiller p&eacute;dagogique uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="discipline_director" x-model="targetRole" class="w-4 h-4" />
