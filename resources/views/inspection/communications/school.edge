    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Formulaire de communication -->
      <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
        <form
          method="POST"
          action="/inspection/communications/school"
          x-data="{ loading: false, preview: false, selectedSchool: null }"
          @submit="loading = true"
        >
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          <div class="mb-4">
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Sélectionner l'école *</label>
            <select name="schoolId" required class="w-full px-3 py-2 border rounded-lg" x-model="selectedSchool">
              <option value="">
                -- Choisir une école --
              </option>
              @each(school in schools)
                <option value="{{ school.id }}">
                  {{ school.name }} ({{ school.province }})
                </option>
              @end
            </select>
          </div>

          <div x-show="selectedSchool" x-cloak>
            <div class="mb-4">
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Objet *</label>
              <input
                type="text"
                name="subject"
                required
                class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-primary"
                placeholder="Ex: Prochaine inspection"
              />
            </div>

            <div class="mb-4">
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Contenu du message *</label>
              <textarea
                name="content"
                rows="8"
                required
                class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-primary"
                placeholder="Saisissez votre message ici..."
              ></textarea>
            </div>

            <div class="mb-4">
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Destinataires spécifiques (optionnel)</label>
              <div class="grid grid-cols-2 gap-3">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="all" checked class="w-4 h-4" />
                  <span>Tous les utilisateurs de l'école</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="director" class="w-4 h-4" />
                  <span>Directeur uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="teacher" class="w-4 h-4" />
                  <span>Enseignants uniquement</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="radio" name="targetRole" value="parent" class="w-4 h-4" />
                  <span>Parents uniquement</span>
                </label>
              </div>
            </div>

            <div class="mb-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="requireAcknowledgment" class="w-4 h-4" />
                <span>Exiger un accusé de réception</span>
              </label>
            </div>

            <div class="flex gap-3">
              <button
                type="button"
                @click="preview = !preview"
                class="px-4 py-2 border rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700"
              >
                <i class="fas fa-eye mr-2"></i>Aperçu
          </button>
              <button
                type="submit"
                :disabled="loading"
                class="flex-1 px-6 py-2 bg-primary text-white rounded-lg hover:bg-blue-700"
              >
                <i x-show="loading" class="fas fa-spinner fa-spin mr-2"></i>
                <span>Envoyer le message</span>
              </button>
