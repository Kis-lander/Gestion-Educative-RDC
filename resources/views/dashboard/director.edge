    <!-- Performance récente -->
    <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl p-4 shadow-md">
      <div class="flex justify-between items-center mb-4">
        <h3 class="font-semibold text-gray-800 dark:text-white">
          Performance scolaire
        </h3>
        <select id="classSelect" class="text-sm border rounded-lg px-2 py-1">
          <option value="">
            Toutes les classes
          </option>
          @each(classObj in classes)
            <option value="{{ classObj.id }}">
              {{ classObj.name }}
            </option>
          @end
        </select>
      </div>
      <div class="table-responsive">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-700">
            <tr>
              <th class="px-3 py-2 text-left">
                Classe
              </th>
              <th class="px-3 py-2 text-center">
                Effectif
              </th>
              <th class="px-3 py-2 text-center">
                Moyenne
              </th>
              <th class="px-3 py-2 text-center">
                Taux présence
              </th>
              <th class="px-3 py-2 text-center">
                Actions
              </th>
            </tr>
          </thead>
          <tbody>
            @each(classPerf in classPerformance)
              <tr>
                <td class="px-3 py-2 font-medium">
                  {{ classPerf.name }}
                </td>
                <td class="px-3 py-2 text-center">
                  {{ classPerf.studentsCount }}
                </td>
                <td class="px-3 py-2 text-center">
                  <span
                    class="font-bold {{ classPerf.averageGrade === '-' ? 'text-gray-500' : (classPerf.averageGrade >= 15 ? 'text-green-600' : (classPerf.averageGrade >= 10 ? 'text-yellow-600' : 'text-red-600')) }}"
                  >
                    {{ classPerf.averageGrade || '-' }}/20
                  </span>
                  </td>
                  <td class="px-3 py-2 text-center">
                    <div class="flex items-center justify-center gap-2">
                      <div class="w-16 bg-gray-200 rounded-full h-1.5">
                        <div class="bg-green-500 rounded-full h-1.5" style="width: {{ classPerf.attendanceRate || 0 }}%">
                        </div>
                      </div>
                      <span class="text-xs">{{ classPerf.attendanceRate || 0 }}%</span>
                    </div>
                  </td>
                  <td class="px-3 py-2 text-center">
                    <a href="/academic/classes/{{ classPerf.id }}" class="text-primary hover:underline text-xs">Voir</a>
                  </td>
                </tr>
                @else
                <tr>
                  <td colspan="5" class="text-center py-6 text-gray-500">
