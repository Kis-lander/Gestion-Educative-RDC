            </tbody>
          </table>
        </div>
      </div>

      <script>
        document.getElementById("classSelect")?.addEventListener("change", function(e) {
          const classId = e.target.value;
          if (classId) {
            window.location.href = `/academic/classes/${classId}`;
          }
        });
      </script>
    @endsection
    
