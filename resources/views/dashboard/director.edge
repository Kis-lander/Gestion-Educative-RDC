      <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-md">
        <h3 class="font-semibold text-gray-800 dark:text-white mb-3">
          Alertes
        </h3>
        <div class="space-y-2">
          @each(alert in alerts)
            <div
              class="p-3 rounded-lg border-l-4"
              :class="{
        'border-yellow-500 bg-yellow-50 dark:bg-yellow-900/20': '{{ alert.type }}' === 'warning',
        'border-red-500 bg-red-50 dark:bg-red-900/20': '{{ alert.type }}' === 'danger',
        'border-blue-500 bg-blue-50 dark:bg-blue-900/20': '{{ alert.type }}' === 'info'
      }"
            >
              <p class="text-sm text-gray-700 dark:text-gray-300">
                {{ alert.message }}
              </p>
              <p class="text-xs text-gray-400 mt-1">
                {{ alert.time }}
              </p>
            </div>
            @else
            <p class="text-gray-500 dark:text-gray-400 text-center py-6">
              Aucune alerte
            </p>
