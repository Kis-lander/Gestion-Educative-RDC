            {{ (student.name || 'Élève').charAt(0) }}
          </div>
          <div>
            <h3 class="font-bold text-lg">
              {{ student.name }}
            </h3>
            <p class="text-sm text-gray-500">
              {{ student.className }} - {{ student.registrationNumber }}
