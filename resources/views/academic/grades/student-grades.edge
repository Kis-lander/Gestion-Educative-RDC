            <span>{{ student.parentPhone || '-' }}</span>
          </div>
        </div>
      </div>

      <!-- Résumé des performances -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-5">
        <h3 class="font-semibold mb-3">
