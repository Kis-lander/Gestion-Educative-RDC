    </div>

    <script>
      let distributionChart;

      function renderChart() {
        const ctx = document.getElementById("distributionChart").getContext("2d");
        distributionChart = new Chart(ctx, {
          type: "bar",
          data: {
            labels: [ "0-5", "5-10", "10-12", "12-14", "14-16", "16-18", "18-20" ],
            datasets: [ {
              label: "Nombre d'élèves",
              data: {{ distributionData|json_encode|raw }},
              backgroundColor: "#2563eb",
              borderRadius: 8
            } ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
              y: {
                beginAtZero: true,
                stepSize: 1,
                precision: 0
              }
            }
          }
        });
      }

      function exportAll() {
        window.location.href = `/api/report-cards/class/{{ classId }}/export?term={{ term }}&year={{ academicYear }}`;
      }

      function publishAll() {
        if (confirm("Publier tous les bulletins de cette classe ? Les parents et élèves pourront les consulter.")) {
          fetch("/academic/report-cards/class/{{ classId }}/publish", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            },
            body: JSON.stringify({
              term: "{{ term }}",
              academicYear: "{{ academicYear }}"
            })
          }).then(res => res.json()).then(data => {
            if (data.success) {
              alert("Tous les bulletins ont été publiés");
              location.reload();
            } else {
              alert("Erreur: " + data.message);
            }
          });
        }
      }

      function downloadSinglePDF(reportId) {
        window.open(`/academic/report-cards/${reportId}/pdf`, "_blank");
      }

      renderChart();
    </script>
  @endsection
  
