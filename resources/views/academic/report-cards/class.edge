            <div class="flex justify-between items-center p-2 border-b">
              <div class="flex items-center gap-3">
                <div
                  class="w-8 h-8 rounded-full bg-{{ top.rank == 1 ? 'yellow' : (top.rank == 2 ? 'gray' : 'orange') }}-500 text-white flex items-center justify-center font-bold"
                >
                  {{ top.rank }}
                </div>
                <span>{{ top.name }}</span>
              </div>
