    <script>
      function publishReport() {
        if (confirm("Publier ce bulletin ? Il deviendra visible par les parents et l'Ã©lÃ¨ve.")) {
          fetch("/academic/report-cards/{{ reportId }}/publish", {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) {
              location.reload();
            } else {
              alert("Erreur: " + data.message);
            }
          });
        }
      }
    </script>

    <style>
