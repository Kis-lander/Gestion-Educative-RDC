      @include('partials/pagination', { pagination: pagination, url: '/academic/report-cards' })
    </div>

    <script>
      const filterClass = document.getElementById("filterClass");

      const filterStudent = document.getElementById("filterStudent");

      const filterTerm = document.getElementById("filterTerm");

      const filterYear = document.getElementById("filterYear");

      const applyBtn = document.getElementById("applyFilters");

      const resetBtn = document.getElementById("resetFilters");

      applyBtn.addEventListener("click", () => {
        const params = new URLSearchParams();
        if (filterClass.value) params.set("class_id", filterClass.value);
        if (filterStudent.value) params.set("student", filterStudent.value);
        if (filterTerm.value) params.set("term", filterTerm.value);
        if (filterYear.value) params.set("year", filterYear.value);
        window.location.href = `/academic/report-cards?${params.toString()}`;
      });

      resetBtn.addEventListener("click", () => {
        window.location.href = "/academic/report-cards";
      });

      function downloadPDF(reportId) {
        window.open(`/academic/report-cards/${reportId}/pdf`, "_blank");
      }

      function exportAll() {
        const params = new URLSearchParams();
        if (filterClass.value) params.set("class_id", filterClass.value);
        if (filterTerm.value) params.set("term", filterTerm.value);
        if (filterYear.value) params.set("year", filterYear.value);
        window.location.href = `/api/report-cards/export?${params.toString()}`;
      }
    </script>
  @endsection
  
