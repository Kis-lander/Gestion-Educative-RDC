            Annuler
      </a>
        </div>
      </form>
    </div>

    <script>
      let termCounter = 1;

      function addTerm() {
        const container = document.getElementById("termsContainer");
        const termDiv = document.createElement("div");
        termDiv.className = "term-item p-3 border rounded-lg mt-3";
        termDiv.innerHTML = `
                <div class="flex justify-between items-center mb-2">
                  <h4 class="font-medium">Trimestre ${termCounter + 1}</h4>
                  <button type="button" onclick="removeTerm(this)" class="text-red-500 text-sm">Supprimer</button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">Nom</label>
                    <input type="text" name="terms[${termCounter}][name]" value="Trimestre ${termCounter + 1}" class="w-full px-2 py-1 border rounded text-sm">
                  </div>
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">Date dÃ©but</label>
                    <input type="date" name="terms[${termCounter}][startDate]" class="w-full px-2 py-1 border rounded text-sm">
                  </div>
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">Date fin</label>
                    <input type="date" name="terms[${termCounter}][endDate]" class="w-full px-2 py-1 border rounded text-sm">
                  </div>
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">DÃ©but examens</label>
                    <input type="date" name="terms[${termCounter}][examStartDate]" class="w-full px-2 py-1 border rounded text-sm">
                  </div>
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">Fin examens</label>
                    <input type="date" name="terms[${termCounter}][examEndDate]" class="w-full px-2 py-1 border rounded text-sm">
                  </div>
                </div>
              `;
        container.appendChild(termDiv);
        termCounter++;
      }

      function removeTerm(btn) {
        btn.closest(".term-item").remove();
      }
      // Dates par dÃ©faut

      const startDateInput = document.querySelector('input[name="startDate"]');

      const endDateInput = document.querySelector('input[name="endDate"]');

      const today = new Date();

      const defaultStart = new Date(today.getFullYear(), 8, 1);

      const defaultEnd = new Date(today.getFullYear() + 1, 5, 30);

      startDateInput.value = defaultStart.toISOString().split("T")[0];

      endDateInput.value = defaultEnd.toISOString().split("T")[0];
    </script>
  @endsection
  
