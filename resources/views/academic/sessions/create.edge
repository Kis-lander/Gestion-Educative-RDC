              </h3>
              <button type="button" onclick="addTerm()" class="text-primary text-sm hover:underline">
                <i class="fas fa-plus mr-1"></i>Ajouter un trimestre
          </button>
            </div>

            <div id="termsContainer" class="space-y-3">
              <div class="term-item p-3 border rounded-lg">
                <div class="flex justify-between items-center mb-2">
                  <h4 class="font-medium">
                    Trimestre 1
                  </h4>
                  <button type="button" onclick="removeTerm(this)" class="text-red-500 text-sm">Supprimer</button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">Nom</label>
                    <input
                      type="text"
                      name="terms[0][name]"
                      value="Premier Trimestre"
                      class="w-full px-2 py-1 border rounded text-sm"
                    />
                  </div>
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">Date dÃ©but</label>
                    <input type="date" name="terms[0][startDate]" class="w-full px-2 py-1 border rounded text-sm" />
                  </div>
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">Date fin</label>
                    <input type="date" name="terms[0][endDate]" class="w-full px-2 py-1 border rounded text-sm" />
                  </div>
                  <div>
                    <label class="block text-gray-600 text-sm mb-1">DÃ©but examens</label>
                    <input type="date" name="terms[0][examStartDate]" class="w-full px-2 py-1 border rounded text-sm" />
                  </div>
