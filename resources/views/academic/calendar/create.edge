                <input type="date" name="recurrenceUntil" class="w-full px-3 py-2 border rounded-lg" />
              </div>
            </div>
          </div>

          <div class="flex gap-3 mt-6 pt-4 border-t">
            <button
              type="submit"
              :disabled="loading"
              class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-blue-700"
            >
              <i x-show="loading" class="fas fa-spinner fa-spin mr-2"></i>
              Ajouter l'événement
        </button>
            <a href="/academic/calendar" class="px-6 py-2 border rounded-lg hover:bg-gray-50">
