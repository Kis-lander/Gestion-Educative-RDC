      <!-- Formulaire -->
      <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
        <form
          method="POST"
          action="/academic/calendar/create"
          x-data="{ loading: false, eventType: 'event' }"
          @submit="loading = true"
        >
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          <div class="space-y-4">
            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Type d'événement *</label>
              <select name="type" required x-model="eventType" class="w-full px-3 py-2 border rounded-lg">
                <option value="event">
                  Événement spécial
                </option>
                <option value="holiday">
                  Vacances / Congé
                </option>
                <option value="exam">
                  Examen
                </option>
                <option value="meeting">
                  Réunion
                </option>
                <option value="deadline">
                  Date limite
                </option>
              </select>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Titre *</label>
              <input
                type="text"
                name="title"
                required
                class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-primary"
                placeholder="Ex: Rentrée scolaire, Vacances de Noël, Conseil de classe..."
              />
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Description</label>
              <textarea
                name="description"
                rows="3"
                class="w-full px-3 py-2 border rounded-lg"
                placeholder="Description détaillée de l'événement..."
              ></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Date début *</label>
                <input type="date" name="startDate" required class="w-full px-3 py-2 border rounded-lg" />
              </div>
              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Heure début</label>
                <input type="time" name="startTime" class="w-full px-3 py-2 border rounded-lg" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Date fin</label>
                <input type="date" name="endDate" class="w-full px-3 py-2 border rounded-lg" />
              </div>
              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Heure fin</label>
                <input type="time" name="endTime" class="w-full px-3 py-2 border rounded-lg" />
              </div>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Lieu</label>
              <input
                type="text"
                name="location"
                class="w-full px-3 py-2 border rounded-lg"
                placeholder="Salle, établissement, ville..."
              />
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Public cible</label>
              <select name="targetAudience" class="w-full px-3 py-2 border rounded-lg">
                <option value="all">
                  Tous
                </option>
                <option value="students">
                  Élèves uniquement
                </option>
                <option value="teachers">
                  Enseignants uniquement
                </option>
                <option value="parents">
                  Parents uniquement
                </option>
                <option value="staff">
                  Personnel uniquement
                </option>
              </select>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Année scolaire *</label>
              <select name="academicYear" required class="w-full px-3 py-2 border rounded-lg">
                <option value="{{ currentYear }}">
                  {{ currentYear }}
                </option>
                <option value="{{ currentYear - 1 }}">
                  {{ currentYear - 1 }}
                </option>
              </select>
            </div>

            <div class="flex items-center gap-4">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="notifyAll" class="w-4 h-4" />
                <span>Notifier tous les utilisateurs</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="recurring" class="w-4 h-4" x-model="recurring" />
                <span>Événement récurrent</span>
              </label>
            </div>

            <div x-show="recurring" x-cloak class="grid grid-cols-2 gap-4 pt-2 border-t">
              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Fréquence</label>
                <select name="recurrenceFrequency" class="w-full px-3 py-2 border rounded-lg">
                  <option value="daily">
