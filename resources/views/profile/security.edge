    <script>
      function setupTwoFactor() {
        alert("L'authentification Ã  deux facteurs n'est pas encore disponible.");
      }

      function disableTwoFactor() {
        if (confirm("Désactiver l'authentification à deux facteurs ?")) {
          fetch("/api/profile/2fa/disable", {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) location.reload(); else alert("Erreur: " + data.message);
          });
        }
      }

      function logoutOtherSessions() {
        if (confirm("Déconnecter toutes les autres sessions ?")) {
          fetch("/api/profile/sessions/logout-others", {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          }).then(res => res.json()).then(data => {
            if (data.success) location.reload(); else alert("Erreur: " + data.message);
          });
        }
      }

      function revokeSession(sessionId) {
        fetch(`/api/profile/sessions/${sessionId}/revoke`, {
          method: "POST",
          headers: {
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          }
        }).then(res => res.json()).then(data => {
          if (data.success) location.reload(); else alert("Erreur: " + data.message);
        });
      }
    </script>
  @endsection
  
