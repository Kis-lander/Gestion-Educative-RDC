                <div
                  class="flex items-center gap-2"
                  :class="/[0-9]/.test(password) ? 'text-green-600' : 'text-gray-400'"
                >
                  <i class="fas" :class="/[0-9]/.test(password) ? 'fa-check-circle' : 'fa-circle'"></i>
                  <span>Au moins un chiffre</span>
                </div>
              </div>
