    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Changement mot de passe -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
        <h3 class="font-semibold text-lg border-b pb-2 mb-4">
          Changer mon mot de passe
        </h3>

        <form
          method="POST"
          action="/profile/change-password"
          x-data="{ loading: false, password: '', confirmPassword: '' }"
          @submit="loading = true"
        >
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          <div class="space-y-4">
            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Mot de passe actuel *</label>
              <input type="password" name="currentPassword" required class="w-full px-3 py-2 border rounded-lg" />
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Nouveau mot de passe *</label>
              <input
                type="password"
                name="newPassword"
