                <p class="text-xs text-gray-500">
                  Notifications pour les nouveaux messages
                </p>
              </div>
              <input
                type="checkbox"
                name="notify_messages"
                value="1"
                class="w-5 h-5"
                {{ preferences.notifyMessages ? 'checked' : '' }}
              />
            </label>

            <label class="flex items-center justify-between cursor-pointer">
              <div>
                <span class="font-medium">Notes et résultats</span>
                <p class="text-xs text-gray-500">
                  Nouvelles notes, bulletins
                </p>
              </div>
              <input
                type="checkbox"
                name="notify_grades"
                value="1"
                class="w-5 h-5"
                {{ preferences.notifyGrades ? 'checked' : '' }}
              />
            </label>

            <label class="flex items-center justify-between cursor-pointer">
              <div>
                <span class="font-medium">Discipline</span>
                <p class="text-xs text-gray-500">
                  Incidents, sanctions
                </p>
              </div>
              <input
                type="checkbox"
                name="notify_discipline"
                value="1"
                class="w-5 h-5"
                {{ preferences.notifyDiscipline ? 'checked' : '' }}
              />
            </label>

            <label class="flex items-center justify-between cursor-pointer">
              <div>
                <span class="font-medium">Paiements</span>
                <p class="text-xs text-gray-500">
                  Échéances, reçus
                </p>
              </div>
              <input
                type="checkbox"
                name="notify_payments"
                value="1"
                class="w-5 h-5"
                {{ preferences.notifyPayments ? 'checked' : '' }}
              />
            </label>

            <label class="flex items-center justify-between cursor-pointer">
              <div>
                <span class="font-medium">Événements</span>
                <p class="text-xs text-gray-500">
                  Événements scolaires, réunions
                </p>
              </div>
              <input
                type="checkbox"
                name="notify_events"
                value="1"
                class="w-5 h-5"
