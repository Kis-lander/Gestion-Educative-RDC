    <!-- Préférences avancées -->
    <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
      <h3 class="font-semibold text-lg border-b pb-2 mb-4">
        Préférences avancées
      </h3>

      <div class="space-y-4">
        <label class="flex items-center justify-between cursor-pointer">
          <div>
            <span class="font-medium">Raccourcis clavier</span>
            <p class="text-xs text-gray-500">
              Activer les raccourcis clavier
            </p>
          </div>
          <input
            type="checkbox"
            name="keyboard_shortcuts"
            class="w-5 h-5"
            {{ preferences.keyboardShortcuts ? 'checked' : '' }}
          />
        </label>

        <label class="flex items-center justify-between cursor-pointer">
          <div>
            <span class="font-medium">Confirmation avant suppression</span>
            <p class="text-xs text-gray-500">
              Demander confirmation avant supprimer
            </p>
          </div>
          <input
            type="checkbox"
            name="confirm_delete"
            class="w-5 h-5"
            {{ preferences.confirmDelete ? 'checked' : '' }}
          />
        </label>

        <label class="flex items-center justify-between cursor-pointer">
          <div>
            <span class="font-medium">Auto-sauvegarde</span>
            <p class="text-xs text-gray-500">
              Sauvegarder automatiquement les formulaires
            </p>
          </div>
          <input type="checkbox" name="auto_save" class="w-5 h-5" {{ preferences.autoSave ? 'checked' : '' }} />
        </label>
      </div>

      <div class="mt-6 pt-4 border-t">
        <button
          onclick="saveAdvancedPrefs()"
          class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-blue-700"
        >
          Enregistrer
    </button>
      </div>
    </div>

    <script>
      function saveAdvancedPrefs() {
        const keyboardShortcuts = document.querySelector('input[name="keyboard_shortcuts"]').checked;
        const confirmDelete = document.querySelector('input[name="confirm_delete"]').checked;
        const autoSave = document.querySelector('input[name="auto_save"]').checked;
        fetch("/api/profile/advanced-preferences", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          },
          body: JSON.stringify({
            keyboardShortcuts: keyboardShortcuts,
            confirmDelete: confirmDelete,
            autoSave: autoSave
          })
        }).then(res => res.json()).then(data => {
          if (data.success) alert("Préférences enregistrées"); else alert("Erreur: " + data.message);
        });
      }
    </script>
  @endsection
  
