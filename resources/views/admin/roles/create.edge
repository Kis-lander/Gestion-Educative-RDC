    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Formulaire -->
      <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
        <form method="POST" action="/admin/roles/create" x-data="{ loading: false }" @submit="loading = true">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          <div class="space-y-4">
            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Nom du rôle *</label>
              <input
                type="text"
                name="name"
                required
                class="w-full px-3 py-2 border rounded-lg focus:ring-2 focus:ring-primary"
                placeholder="Ex: Superviseur, Coordonnateur..."
              />
              <p class="text-xs text-gray-500 mt-1">
                Nom unique, en minuscules, sans espaces (ex: moderateurs)
              </p>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Description</label>
              <textarea
                name="description"
