                class="w-full px-3 py-2 border rounded-lg"
                placeholder="Décrivez l'objectif de ce rôle..."
              ></textarea>
            </div>

            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Statut</label>
              <select name="status" class="w-full px-3 py-2 border rounded-lg">
                <option value="active">
                  Actif
                </option>
                <option value="inactive">
                  Inactif
                </option>
              </select>
            </div>

            <div class="border-t pt-4">
              <h3 class="font-semibold mb-3">
                Permissions de base
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="permissions[]" value="users.view" class="w-4 h-4" />
                  <span class="text-sm">Voir les utilisateurs</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="permissions[]" value="users.create" class="w-4 h-4" />
                  <span class="text-sm">Créer des utilisateurs</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="permissions[]" value="users.edit" class="w-4 h-4" />
                  <span class="text-sm">Modifier des utilisateurs</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="permissions[]" value="users.delete" class="w-4 h-4" />
                  <span class="text-sm">Supprimer des utilisateurs</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="permissions[]" value="schools.view" class="w-4 h-4" />
                  <span class="text-sm">Voir les écoles</span>
                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="permissions[]" value="schools.approve" class="w-4 h-4" />
