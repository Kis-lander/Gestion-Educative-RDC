                  <span>                    <i class="fas fa-calendar mr-1"></i>{{ backup.date }}</span>
                  <span>                    <i class="fas fa-hdd mr-1"></i>{{ backup.size }}</span>
                  <span>                    <i class="fas fa-database mr-1"></i>{{ backup.type }}</span>
                </div>
              </div>
              <div class="flex gap-2">
                <button
                  onclick="downloadBackup('{{ backup.filename }}')"
                  class="text-primary hover:underline text-sm"
                  title="Télécharger"
                >
                  <i class="fas fa-download"></i>
                </button>
                <button
                  onclick="restoreBackup('{{ backup.filename }}')"
                  class="text-yellow-600 hover:text-yellow-800 text-sm"
                  title="Restaurer"
                >
                  <i class="fas fa-trash-restore"></i>
                </button>
                <button
                  onclick="deleteBackup('{{ backup.filename }}')"
                  class="text-red-500 hover:text-red-700 text-sm"
                  title="Supprimer"
                >
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
            @else
            <div class="p-12 text-center text-gray-500">
              <i class="fas fa-database text-5xl mb-3 block"></i>
              <p>
                Aucune sauvegarde disponible
              </p>
              <button onclick="createBackup()" class="mt-3 text-primary hover:underline">
                Créer la première sauvegarde
        </button>
            </div>
          @end
        </div>
      </div>
    </div>

    <!-- Progression de restauration -->
    <div id="restoreModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full p-6">
        <div class="text-center">
          <i class="fas fa-spinner fa-spin text-primary text-3xl mb-3"></i>
          <h3 class="font-bold text-lg mb-2">
            Restauration en cours...
          </h3>
          <p class="text-sm text-gray-500">
            Cette opération peut prendre plusieurs minutes.
          </p>
          <div class="w-full bg-gray-200 rounded-full h-2 mt-4">
            <div id="restoreProgress" class="bg-primary rounded-full h-2" style="width: 0%">
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      async function createBackup() {
        if (confirm("Créer une sauvegarde manuelle ? Cette opération peut prendre quelques minutes.")) {
          const loading = document.createElement("div");
          loading.className = "fixed inset-0 bg-black/50 flex items-center justify-center z-50";
          loading.innerHTML = '<div class="bg-white dark:bg-gray-800 rounded-lg p-8 flex flex-col items-center"><div class="spinner"></div><p class="mt-4">Création de la sauvegarde...</p></div>';
          document.body.appendChild(loading);
          const res = await fetch("/api/admin/backup/create", {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          loading.remove();
          if (data.success) {
            alert("Sauvegarde créée avec succès");
            location.reload();
          } else {
            alert("Erreur: " + data.message);
          }
        }
      }

      function downloadBackup(filename) {
        window.location.href = `/api/admin/backup/download/${filename}`;
      }

      async function restoreBackup(filename) {
        if (confirm(`⚠️ RESTAURATION COMPLÈTE\n\nRestaurer la sauvegarde "${filename}" ?\n\nCette action remplacera TOUTES les données actuelles.\nAssurez-vous d'avoir une sauvegarde récente.\n\nCette opération est IRREVERSIBLE.`)) {
          const modal = document.getElementById("restoreModal");
          modal.classList.remove("hidden");
          modal.classList.add("flex");
          const progress = document.getElementById("restoreProgress");
          let percent = 0;
          const interval = setInterval(() => {
            percent += 10;
            progress.style.width = percent + "%";
            if (percent >= 100) clearInterval(interval);
          }, 500);
          const res = await fetch(`/api/admin/backup/restore/${filename}`, {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          clearInterval(interval);
          modal.classList.add("hidden");
          modal.classList.remove("flex");
          if (data.success) {
            alert("Restauration terminée. La plateforme va redémarrer.");
            window.location.href = "/";
          } else {
            alert("Erreur: " + data.message);
          }
        }
      }

      async function deleteBackup(filename) {
        if (confirm(`Supprimer la sauvegarde "${filename}" ?`)) {
          const res = await fetch(`/api/admin/backup/delete/${filename}`, {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          if (data.success) location.reload(); else alert("Erreur: " + data.message);
        }
      }
    </script>

    <style>
      .spinner {
        border: 3px solid #f3f4f6;
        border-top: 3px solid #2563eb;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
      }
      
      @keyframes spin {
        0% {
          transform: rotate(0deg);
        }
      
        100% {
          transform: rotate(360deg);
        }
      }
    </style>
  @endsection
  
