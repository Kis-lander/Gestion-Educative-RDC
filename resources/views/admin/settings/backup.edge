    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Formulaire -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
        <form
          method="POST"
          action="/admin/settings/backup"
          x-data="{ loading: false }"
          @submit="loading = true"
        >
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          <div class="space-y-4">
            <div>
              <h3 class="font-semibold text-lg border-b pb-2 mb-4">
                Planification
              </h3>

              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Fréquence automatique</label>
                <select name="backup_frequency" class="w-full px-3 py-2 border rounded-lg">
                  <option value="disabled" {{ settings.backupFrequency === 'disabled' ? 'selected' : '' }}>
                    Désactivé
                  </option>
                  <option value="daily" {{ settings.backupFrequency === 'daily' ? 'selected' : '' }}>
                    Quotidienne
                  </option>
                  <option value="weekly" {{ settings.backupFrequency === 'weekly' ? 'selected' : '' }}>
                    Hebdomadaire
                  </option>
                  <option value="monthly" {{ settings.backupFrequency === 'monthly' ? 'selected' : '' }}>
                    Mensuelle
                  </option>
                </select>
              </div>

              <div class="mt-3">
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Heure de sauvegarde</label>
                <input
                  type="time"
                  name="backup_time"
                  value="{{ settings.backupTime || '02:00' }}"
                  class="w-full px-3 py-2 border rounded-lg"
                />
              </div>

              <div class="mt-3">
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Conserver (nombre de sauvegardes)</label>
                <input
                  type="number"
                  name="backup_retention"
                  value="{{ settings.backupRetention || 30 }}"
                  min="1"
                  max="365"
                  class="w-full px-3 py-2 border rounded-lg"
                />
              </div>
            </div>

            <div>
              <h3 class="font-semibold text-lg border-b pb-2 mb-4">
                Contenu des sauvegardes
              </h3>

              <div class="space-y-2">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="backup_database" checked disabled class="w-4 h-4" />
