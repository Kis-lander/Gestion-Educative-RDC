                </label>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="backup_logs" class="w-4 h-4" {{ settings.backupLogs ? 'checked' : '' }} />
                  <span>Logs système</span>
                </label>
              </div>
            </div>

            <div>
              <h3 class="font-semibold text-lg border-b pb-2 mb-4">
                Stockage externe
              </h3>

              <div>
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" name="backup_remote" class="w-4 h-4" {{ settings.backupRemote ? 'checked' : '' }} />
                  <span>Envoyer vers stockage externe</span>
                </label>
              </div>

              <div x-show="backupRemote" class="mt-3 space-y-3">
                <div>
                  <label class="block text-gray-700 dark:text-gray-300 mb-2">Type de stockage</label>
                  <select name="remote_type" class="w-full px-3 py-2 border rounded-lg">
