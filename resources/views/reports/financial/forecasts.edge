        <p class="text-sm opacity-90">
          Revenus projetés
        </p>
        <p class="text-3xl font-bold" id="projectedIncome">
          0 $
        </p>
      </div>
      <div class="bg-gradient-to-br from-red-500 to-red-600 rounded-xl p-4 text-white">
        <p class="text-sm opacity-90">
          Dépenses projetées
        </p>
        <p class="text-3xl font-bold" id="projectedExpenses">
          0 $
        </p>
