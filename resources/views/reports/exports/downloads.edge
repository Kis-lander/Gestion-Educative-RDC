              <div class="flex items-start gap-3">
                <div
                  class="w-10 h-10 rounded-lg flex items-center justify-center
            {{ download.format === 'pdf' ? 'bg-red-100' : 
               (download.format === 'excel' ? 'bg-green-100' : 
               (download.format === 'csv' ? 'bg-blue-100' : 'bg-yellow-100')) }}"
                >
                  <i
                    class="fas {{ download.format === 'pdf' ? 'fa-file-pdf text-red-500' : 
                             (download.format === 'excel' ? 'fa-file-excel text-green-500' : 
                             (download.format === 'csv' ? 'fa-file-csv text-blue-500' : 'fa-file-code text-yellow-500')) }} text-xl"
                  ></i>
                </div>
                <div>
                  <p class="font-medium">
                    {{ download.filename }}
                  </p>
                  <div class="flex flex-wrap gap-3 mt-1 text-xs text-gray-500">
                    <span>                      <i class="fas fa-calendar mr-1"></i>{{ formatDateTime(download.downloadedAt) }}</span>
                    <span>                      <i class="fas fa-database mr-1"></i>{{ download.size || '-' }}</span>
                    <span>                      <i class="fas fa-download mr-1"></i>{{ download.downloadCount || 1 }} téléchargement(s)</span>
                  </div>
                </div>
              </div>
              <div class="flex gap-2">
                <a
                  href="/reports/exports/download/{{ download.id }}"
                  class="px-3 py-1 bg-primary text-white rounded text-sm hover:bg-blue-700"
                >
                  <i class="fas fa-download mr-1"></i>Télécharger
          </a>
                <button
                  onclick="deleteDownload('{{ download.id }}')"
                  class="px-3 py-1 border border-red-300 text-red-600 rounded text-sm hover:bg-red-50"
                >
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
          </div>
