      @include('partials/pagination')
    </div>

    <!-- Espace de stockage -->
    <div class="mt-6 bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
      <h3 class="font-semibold mb-2">
        Espace de stockage
      </h3>
      <div class="flex justify-between text-sm mb-1">
        <span>Utilisé</span>
        <span>{{ storageUsed }} / {{ storageLimit }}</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2">
        <div class="bg-primary rounded-full h-2" style="width: {{ storagePercentage }}%">
        </div>
      </div>
      <p class="text-xs text-gray-400 mt-2">
        Les fichiers sont conservés pendant 30 jours
      </p>
    </div>

    <script>
      const periodFilter = document.getElementById("periodFilter");

      const formatFilter = document.getElementById("formatFilter");

      const applyBtn = document.getElementById("applyFilters");

      applyBtn.addEventListener("click", () => {
        const params = new URLSearchParams();
        if (periodFilter.value !== "all") params.set("period", periodFilter.value);
        if (formatFilter.value) params.set("format", formatFilter.value);
        window.location.href = `/reports/exports/downloads?${params.toString()}`;
      });

      async function deleteDownload(downloadId) {
        if (confirm("Supprimer ce téléchargement ?")) {
          const res = await fetch(`/api/reports/exports/${downloadId}`, {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          if (data.success) location.reload(); else alert("Erreur: " + data.message);
        }
      }
    </script>
  @endsection
  
