  @section('content')
    <form
      method="POST"
      action="/schools/accounts/{{ account.id }}/edit"
      class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 space-y-6"
      x-data="{
        childSearch: '',
        selectedChildrenCount: 0,
        refreshChildrenCount() {
          this.selectedChildrenCount = this.$el.querySelectorAll('[data-child-checkbox]:checked').length
        }
      }"
      x-init="refreshChildrenCount()"
    >
      <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <label class="block">
          <span class="block text-gray-700 dark:text-gray-300 mb-2">Prénom *</span>
          <input name="firstName" value="{{ account.firstName }}" required class="w-full px-3 py-2 border rounded-lg" />
        </label>

        <label class="block">
          <span class="block text-gray-700 dark:text-gray-300 mb-2">Nom *</span>
          <input name="lastName" value="{{ account.lastName }}" required class="w-full px-3 py-2 border rounded-lg" />
        </label>

        <label class="block">
          <span class="block text-gray-700 dark:text-gray-300 mb-2">Postnom *</span>
          <input name="postnom" value="{{ account.postnom || '' }}" required class="w-full px-3 py-2 border rounded-lg" />
        </label>

        <label class="block">
          <span class="block text-gray-700 dark:text-gray-300 mb-2">Email *</span>
          <input type="email" name="email" value="{{ account.email }}" required class="w-full px-3 py-2 border rounded-lg" />
        </label>

        <label class="block">
          <span class="block text-gray-700 dark:text-gray-300 mb-2">Téléphone</span>
          <input type="tel" name="phone" value="{{ account.phone || '' }}" class="w-full px-3 py-2 border rounded-lg" />
        </label>

        <label class="block">
          <span class="block text-gray-700 dark:text-gray-300 mb-2">Statut</span>
          <select name="status" class="w-full px-3 py-2 border rounded-lg">
            <option value="active" {{ account.status === 'active' ? 'selected' : '' }}>Actif</option>
            <option value="inactive" {{ account.status === 'inactive' ? 'selected' : '' }}>Inactif</option>
            <option value="suspended" {{ account.status === 'suspended' ? 'selected' : '' }}>Suspendu</option>
            <option value="pending" {{ account.status === 'pending' ? 'selected' : '' }}>En attente</option>
