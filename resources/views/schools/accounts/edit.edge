                <option
                  value="{{ classObj.id }}"
                  data-humanities="{{ classObj.level?.toLowerCase().includes('humanit') || classObj.gradeLevel >= 9 ? 'true' : 'false' }}"
                  {{ student?.classId === classObj.id ? 'selected' : '' }}
                >
                  {{ classObj.name }}
                </option>
              @end
            </select>
          </label>
          <label id="accountEditSchoolOptionField" class="block hidden">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Option *</span>
            <select name="schoolOption" id="accountEditSchoolOptionSelect" class="w-full px-3 py-2 border rounded-lg">
              <option value="">Sélectionner une option</option>
              @each(option in schoolOptions)
                <option value="{{ option }}" {{ student?.schoolOption === option ? 'selected' : '' }}>{{ option }}</option>
              @end
            </select>
          </label>
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Sexe</span>
            <select name="gender" class="w-full px-3 py-2 border rounded-lg">
              <option value="">Sélectionner</option>
              <option value="male" {{ student?.gender === 'male' ? 'selected' : '' }}>Masculin</option>
