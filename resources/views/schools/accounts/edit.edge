          </label>
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Spécialisation</span>
            <input name="specialization" value="{{ teacher?.specialization || '' }}" class="w-full px-3 py-2 border rounded-lg" />
          </label>
        </div>
      @endif

      @if(account.role === 'student')
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block">
