          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Lieu de naissance</span>
            <input name="birthPlace" value="{{ student?.birthPlace || '' }}" class="w-full px-3 py-2 border rounded-lg" />
          </label>
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Nationalité</span>
            <input name="nationality" value="{{ student?.nationality || 'Congolaise' }}" class="w-full px-3 py-2 border rounded-lg" />
          </label>
          <label class="block md:col-span-2">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Adresse</span>
            <textarea name="address" rows="2" class="w-full px-3 py-2 border rounded-lg">{{ student?.address || '' }}</textarea>
          </label>
          <label class="block md:col-span-2">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Informations médicales</span>
            <textarea name="medicalInfo" rows="2" class="w-full px-3 py-2 border rounded-lg">{{ student?.medicalInfo || '' }}</textarea>
          </label>
        </div>
      @endif

      @if(account.role === 'parent')
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Lien de parenté</span>
            <input name="relationship" value="{{ parent?.relationship || '' }}" class="w-full px-3 py-2 border rounded-lg" />
          </label>
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Téléphone d'urgence</span>
            <input type="tel" name="emergencyPhone" value="{{ parent?.emergencyPhone || '' }}" class="w-full px-3 py-2 border rounded-lg" />
          </label>
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Profession</span>
            <input name="profession" value="{{ parent?.profession || '' }}" class="w-full px-3 py-2 border rounded-lg" />
          </label>
          <div class="md:col-span-2 rounded-lg border dark:border-gray-700 p-4">
            <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
              <div>
                <h3 class="font-semibold text-gray-800 dark:text-white">Rattachement parent-élève</h3>
                <p class="text-sm text-gray-500">Cochez les élèves rattachés à ce parent.</p>
              </div>
              <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-sm font-medium">
                <span x-text="selectedChildrenCount"></span> sélectionné(s)
              </span>
            </div>

            <input
              type="search"
              x-model="childSearch"
              placeholder="Rechercher par nom, matricule ou classe"
              class="w-full px-3 py-2 border rounded-lg mb-3"
            />

            <div class="max-h-72 overflow-y-auto divide-y dark:divide-gray-700 border dark:border-gray-700 rounded-lg">
              @each(child in students)
                <label
                  class="flex items-start gap-3 p-3 hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer"
                  data-search="{{ (child.user.fullName + ' ' + child.registrationNumber + ' ' + (child.class ? child.class.name : '')).toLowerCase() }}"
                  x-show="$el.dataset.search.includes(childSearch.toLowerCase())"
                >
                  <input
                    type="checkbox"
                    name="childrenIds[]"
                    value="{{ child.id }}"
                    {{ selectedChildrenIds.includes(child.id) ? 'checked' : '' }}
                    data-child-checkbox
                    @change="refreshChildrenCount()"
                    class="mt-1 w-4 h-4"
                  />
                  <span class="flex-1">
                    <span class="block font-medium text-gray-800 dark:text-white">
                      {{ child.user.fullName }}
                    </span>
                    <span class="block text-xs text-gray-500">
                      Matricule: {{ child.registrationNumber }}{{ child.class ? ' - Classe: ' + child.class.name : ' - Classe non affectée' }}
                    </span>
                  </span>
                </label>
                @else
                <p class="p-4 text-center text-gray-500">Aucun élève disponible dans cette école.</p>
              @end
            </div>
          </div>
        </div>
      @endif

      <div class="flex gap-3 pt-4 border-t">
        <button type="submit" class="px-6 py-2 bg-primary text-white rounded-lg hover:bg-blue-700">
          <i class="fas fa-save mr-2"></i>Enregistrer
        </button>
        <a href="/schools/accounts" class="px-6 py-2 border rounded-lg hover:bg-gray-50">
          Annuler
        </a>
      </div>
    </form>

    <script>
      const accountEditClassSelect = document.getElementById("accountEditClassSelect");
      const accountEditOptionField = document.getElementById("accountEditSchoolOptionField");
      const accountEditOptionSelect = document.getElementById("accountEditSchoolOptionSelect");

      function syncAccountEditSchoolOptionField() {
        const selectedOption = accountEditClassSelect?.selectedOptions?.[0];
        const isHumanities = selectedOption?.dataset.humanities === "true";
        accountEditOptionField?.classList.toggle("hidden", !isHumanities);
        if (accountEditOptionSelect) {
          accountEditOptionSelect.required = isHumanities;
          if (!isHumanities) accountEditOptionSelect.value = "";
        }
      }

      accountEditClassSelect?.addEventListener("change", syncAccountEditSchoolOptionField);
      syncAccountEditSchoolOptionField();
    </script>
  @endsection
