          </label>
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Date de naissance</span>
            <input type="date" name="birthDate" value="{{ student?.birthDate ? student.birthDate.toFormat('yyyy-MM-dd') : '' }}" class="w-full px-3 py-2 border rounded-lg" />
          </label>
          <label class="block">
            <span class="block text-gray-700 dark:text-gray-300 mb-2">Téléphone parent</span>
            <input type="tel" name="parentPhone" value="{{ student?.parentPhone || '' }}" class="w-full px-3 py-2 border rounded-lg" />
