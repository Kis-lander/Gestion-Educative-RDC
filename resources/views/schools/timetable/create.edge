        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-4">
          <h3 class="font-semibold mb-2">
            Raccourcis
          </h3>
          <div class="space-y-2 text-sm">
            <button
              type="button"
              onclick="clearDay('monday')"
              class="w-full text-left px-3 py-1 border rounded hover:bg-gray-50"
            >
              <i class="fas fa-eraser mr-2"></i>Effacer Lundi
        </button>
            <button
              type="button"
              onclick="copyDay('monday', 'tuesday')"
              class="w-full text-left px-3 py-1 border rounded hover:bg-gray-50"
            >
              <i class="fas fa-copy mr-2"></i>Copier Lundi → Mardi
        </button>
          </div>
        </div>
      </div>
    </div>

    <script>
      const timeSlots = [ {
        start: "08:00",
        end: "09:00",
        label: "08:00-09:00"
      }, {
        start: "09:00",
        end: "10:00",
        label: "09:00-10:00"
      }, {
        start: "10:00",
        end: "11:00",
        label: "10:00-11:00"
      }, {
        start: "11:00",
        end: "12:00",
        label: "11:00-12:00"
      }, {
        start: "13:00",
        end: "14:00",
        label: "13:00-14:00"
      }, {
        start: "14:00",
        end: "15:00",
        label: "14:00-15:00"
      }, {
        start: "15:00",
        end: "16:00",
        label: "15:00-16:00"
      }, {
        start: "16:00",
        end: "17:00",
        label: "16:00-17:00"
      } ];

      const days = [ "monday", "tuesday", "wednesday", "thursday", "friday", "saturday" ];

      const dayLabels = [ "Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi", "Samedi" ];

      let subjects = [];

      let teachers = [];

      async function loadSubjects() {
        const classId = document.querySelector("[name=classId]").value;
        if (!classId) return;
        const res = await fetch(`/api/classes/${classId}/subjects`);
        const data = await res.json();
        subjects = data.subjects || [];
        // Also load teachers for the school
        const teachersRes = await fetch("/api/teachers/list");
        const teachersData = await teachersRes.json();
        teachers = teachersData.teachers || [];
        renderTimetableGrid();
      }

      function renderTimetableGrid() {
        const tbody = document.getElementById("timetableGrid");
        let html = "";
        timeSlots.forEach((slot, slotIndex) => {
          html += `<tr class="border-b dark:border-gray-700">`;
          html += `<td class="px-2 py-2 font-medium bg-gray-50 dark:bg-gray-700">${slot.label}</td>`;
          days.forEach((day, dayIndex) => {
            html += `
                    <td class="px-1 py-1">
                      <select name="schedule[${day}][${slotIndex}][subjectId]" class="w-full px-1 py-1 border rounded text-xs mb-1">
                        <option value="">-- Matière --</option>
                        ${subjects.map(s => `<option value="${s.subject_id}">${s.subject_name}</option>`).join("")}
                      </select>
                      <select name="schedule[${day}][${slotIndex}][teacherId]" class="w-full px-1 py-1 border rounded text-xs mb-1">
                        <option value="">-- Enseignant --</option>
                        ${teachers.map(t => `<option value="${t.id}">${t.user.fullName || [t.user.firstName, t.user.lastName, t.user.postnom].filter(Boolean).join(" ")}</option>`).join("")}
                      </select>
                      <input type="text" name="schedule[${day}][${slotIndex}][room]" placeholder="Salle" class="w-full px-1 py-1 border rounded text-xs">
                    </td>
                  `;
          });
          html += `</tr>`;
        });
        tbody.innerHTML = html;
      }

      function clearDay(day) {
        const dayIndex = days.indexOf(day);
        if (dayIndex === -1) return;
        for (let i = 0; i < timeSlots.length; i++) {
          const subjectSelect = document.querySelector(`select[name="schedule[${day}][${i}][subjectId]"]`);
          const teacherSelect = document.querySelector(`select[name="schedule[${day}][${i}][teacherId]"]`);
          const roomInput = document.querySelector(`input[name="schedule[${day}][${i}][room]"]`);
          if (subjectSelect) subjectSelect.value = "";
          if (teacherSelect) teacherSelect.value = "";
          if (roomInput) roomInput.value = "";
        }
      }

      function copyDay(fromDay, toDay) {
        const fromIndex = days.indexOf(fromDay);
        const toIndex = days.indexOf(toDay);
        if (fromIndex === -1 || toIndex === -1) return;
        for (let i = 0; i < timeSlots.length; i++) {
          const fromSubject = document.querySelector(`select[name="schedule[${fromDay}][${i}][subjectId]"]`)?.value;
          const fromTeacher = document.querySelector(`select[name="schedule[${fromDay}][${i}][teacherId]"]`)?.value;
          const fromRoom = document.querySelector(`input[name="schedule[${fromDay}][${i}][room]"]`)?.value;
          const toSubject = document.querySelector(`select[name="schedule[${toDay}][${i}][subjectId]"]`);
          const toTeacher = document.querySelector(`select[name="schedule[${toDay}][${i}][teacherId]"]`);
          const toRoom = document.querySelector(`input[name="schedule[${toDay}][${i}][room]"]`);
          if (toSubject) toSubject.value = fromSubject || "";
          if (toTeacher) toTeacher.value = fromTeacher || "";
          if (toRoom) toRoom.value = fromRoom || "";
        }
      }
      // Observer le changement de classe

      document.querySelector("[name=classId]").addEventListener("change", loadSubjects);
      if (document.querySelector("[name=classId]").value) {
        loadSubjects();
      }
    </script>
  @endsection
  
