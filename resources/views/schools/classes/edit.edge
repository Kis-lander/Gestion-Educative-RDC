    <script>
      function deleteClass() {
        fetch("/schools/classes/{{ classObj.id }}", {
          method: "DELETE",
          headers: {
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          }
        }).then(res => res.json()).then(data => {
          if (data.success) {
            window.location.href = "/schools/classes";
          } else {
            alert("Erreur: " + data.message);
          }
        });
      }
    </script>
