        <!-- Tab: API -->
        <div id="settings-panel-api" class="settings-panel hidden">
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6">
            <h3 class="font-semibold text-lg border-b pb-3 mb-4">
              Intégration API
            </h3>

            <div class="space-y-4">
              <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
                <p class="font-medium mb-2">
                  Clé API
                </p>
                <div class="flex gap-2">
                  <input
                    type="text"
                    id="apiKey"
                    value="{{ settings.apiKey || 'Non générée' }}"
                    readonly
                    class="flex-1 px-3 py-2 bg-gray-100 dark:bg-gray-600 rounded font-mono text-sm"
                  />
                  <button onclick="regenerateApiKey()" class="px-3 py-2 border rounded-lg hover:bg-gray-100">
                    <i class="fas fa-sync-alt"></i>
                  </button>
                </div>
                <p class="text-xs text-gray-500 mt-2">
                  Utilisez cette clé pour les intégrations externes
                </p>
              </div>

              <div>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" name="enable_api" class="w-4 h-4" {{ settings.enableAPI ? 'checked' : '' }} />
                  <span>Activer l'API externe</span>
                </label>
              </div>

              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Webhooks</label>
                <textarea
                  name="webhooks"
                  rows="3"
                  class="w-full px-3 py-2 border rounded-lg font-mono text-sm"
                  placeholder="https://votre-serveur.com/webhook"
                >{{ settings.webhooks || '' }}</textarea>
              </div>

              <div class="pt-4 border-t">
                <button onclick="testApiConnection()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">
                  <i class="fas fa-plug mr-2"></i>Tester la connexion API
            </button>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <script>
      let currentSettingsTab = "general";

      function showSettingsTab(tabName) {
        document.querySelectorAll(".settings-panel").forEach(panel => {
          panel.classList.add("hidden");
        });
        document.getElementById(`settings-panel-${tabName}`).classList.remove("hidden");
        document.querySelectorAll('[id^="settings-tab-"]').forEach(tab => {
          tab.classList.remove("bg-gray-100", "dark:bg-gray-700", "font-semibold");
        });
        document.getElementById(`settings-tab-${tabName}`).classList.add("bg-gray-100", "dark:bg-gray-700", "font-semibold");
        currentSettingsTab = tabName;
      }

      function regenerateApiKey() {
        fetch("/api/schools/settings/regenerate-api-key", {
          method: "POST",
          headers: {
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          }
        }).then(res => res.json()).then(data => {
          if (data.apiKey) {
            document.getElementById("apiKey").value = data.apiKey;
            alert("Nouvelle clé API générée");
          }
        });
      }

      function testApiConnection() {
        fetch("/api/schools/settings/test-api").then(res => res.json()).then(data => {
          alert(data.success ? "Connexion API réussie" : "Erreur de connexion API");
        });
      }

      function syncUsers() {
        fetch("/api/schools/settings/sync-users", {
          method: "POST",
          headers: {
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          }
        }).then(res => res.json()).then(data => {
          alert(`${data.synced || 0} utilisateurs synchronisés`);
        });
      }

      function clearAllData() {
        if (confirm("⚠️ ATTENTION : Cette action supprimera TOUTES les données de l'école. Êtes-vous absolument sûr ?")) {
          if (prompt('Tapez "CONFIRMER" pour valider') === "CONFIRMER") {
            fetch("/api/schools/settings/clear-data", {
              method: "DELETE",
              headers: {
                "X-CSRF-TOKEN": "{{ csrfToken }}"
              }
            }).then(res => res.json()).then(data => {
              alert(data.success ? "Données réinitialisées" : "Erreur");
              if (data.success) window.location.href = "/";
            });
          }
        }
      }

      showSettingsTab("general");
    </script>
  @endsection
  
