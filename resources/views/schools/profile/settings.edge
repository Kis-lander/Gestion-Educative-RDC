              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Session expiration (minutes)</label>
                <input
                  type="number"
                  name="session_timeout"
                  value="{{ settings.sessionTimeout || 60 }}"
                  min="15"
                  max="480"
                  class="w-full px-3 py-2 border rounded-lg"
                />
              </div>

              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">IP autorisées (une par ligne)</label>
                <textarea
                  name="whitelist_ips"
                  rows="3"
                  class="w-full px-3 py-2 border rounded-lg font-mono text-sm"
                  placeholder="192.168.1.1&#10;10.0.0.0/24"
                >{{ settings.whitelistIPs || '' }}</textarea>
              </div>

              <div class="pt-4 border-t">
                <h4 class="font-medium mb-3 text-red-600">
                  Zone dangereuse
                </h4>
                <button onclick="clearAllData()" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700">
                  <i class="fas fa-trash-alt mr-2"></i>Réinitialiser toutes les données
            </button>
                <p class="text-xs text-gray-500 mt-2">
                  Cette action est irréversible
                </p>
              </div>
