      <!-- Step 2: Informations du directeur -->
      <div x-show="step === 2" x-cloak>
        <h3 class="font-semibold text-lg mb-4 text-gray-700 dark:text-gray-300">
          <span
            class="bg-primary text-white w-6 h-6 inline-flex items-center justify-center rounded-full text-sm mr-2"
          >2</span>
          Informations du directeur
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Nom complet *</label>
            <input
              type="text"
              name="directorName"
              required
              class="w-full px-4 py-2 border rounded-lg"
              placeholder="Jean MUKADI"
            />
          </div>

          <div>
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Téléphone *</label>
            <input
              type="tel"
              name="directorPhone"
              required
              class="w-full px-4 py-2 border rounded-lg"
              placeholder="+243 XXX XXX XXX"
            />
          </div>

          <div>
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Email (optionnel)</label>
            <input
              type="email"
              name="directorEmail"
              class="w-full px-4 py-2 border rounded-lg"
              placeholder="directeur@ecole.cd"
            />
          </div>
        </div>
      </div>

      <!-- Step 3: Confirmation -->
      <div x-show="step === 3" x-cloak>
        <h3 class="font-semibold text-lg mb-4 text-gray-700 dark:text-gray-300">
          <span
            class="bg-primary text-white w-6 h-6 inline-flex items-center justify-center rounded-full text-sm mr-2"
          >3</span>
          Confirmation
        </h3>
        <div class="bg-yellow-50 dark:bg-yellow-900/20 border-l-4 border-yellow-500 rounded-lg p-4 mb-4">
          <p class="text-sm text-gray-700 dark:text-gray-300 mb-2">
            <i class="fas fa-info-circle text-yellow-600 mr-2"></i>
            En soumettant ce formulaire, vous acceptez que :
          </p>
          <ul class="list-disc list-inside text-sm text-gray-600 dark:text-gray-400 space-y-1 ml-4">
            <li>
              Les informations fournies sont exactes et vérifiables
            </li>
            <li>
              L'école sera soumise à validation par l'Inspection Pédagogique
