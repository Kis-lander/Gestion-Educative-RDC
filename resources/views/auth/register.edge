          <div class="md:col-span-2">
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Adresse *</label>
            <input
              type="text"
              name="address"
              required
              class="w-full px-4 py-2 border rounded-lg"
              placeholder="Numéro, avenue/lac, quartier"
            />
