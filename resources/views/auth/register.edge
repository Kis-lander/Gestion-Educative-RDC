        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="md:col-span-2">
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Nom de l'école *</label>
            <input
              type="text"
              name="name"
              required
              class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-primary"
              placeholder="Ex: Collège Saint Joseph"
            />
          </div>

          <div>
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Province *</label>
            <select name="province" required class="w-full px-4 py-2 border rounded-lg">
