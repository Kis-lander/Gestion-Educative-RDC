              </option>
              <option value="Kasaï-Central">
                Kasaï-Central
              </option>
              <option value="Kasaï-Oriental">
                Kasaï-Oriental
              </option>
              <option value="Haut-Lomami">
                Haut-Lomami
              </option>
              <option value="Lualaba">
                Lualaba
              </option>
              <option value="Haut-Katanga">
                Haut-Katanga
              </option>
            </select>
          </div>

          <div>
            <label class="block text-gray-700 dark:text-gray-300 mb-2">Territoire / Commune *</label>
            <input
              type="text"
              name="territory"
              required
              class="w-full px-4 py-2 border rounded-lg"
              placeholder="Ex: Gombe, Lukunga, etc."
            />
