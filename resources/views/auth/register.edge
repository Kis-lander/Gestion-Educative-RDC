        <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4">
          <p class="text-sm font-medium mb-2">
            Récapitulatif :
          </p>
          <div class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
            <p>
              <span class="font-medium">École :</span>              <span x-text="document.querySelector('[name=name]')?.value || '-'"></span>
            </p>
            <p>
              <span class="font-medium">Province :</span>              <span x-text="document.querySelector('[name=province]')?.value || '-'"></span>
            </p>
            <p>
              <span class="font-medium">Directeur :</span>              <span x-text="document.querySelector('[name=directorName]')?.value || '-'"></span>
            </p>
          </div>
        </div>
      </div>

      <!-- Navigation steps -->
      <div class="flex items-center justify-between gap-3 mt-8 pt-4 border-t dark:border-gray-700">
        <button
          type="button"
          x-show="step > 1"
          @click="step--"
          class="px-4 py-2 border border-white text-white rounded-lg hover:bg-white/10 transition"
        >
          <i class="fas fa-chevron-left mr-2"></i>Précédent
      </button>
        <button
          type="button"
          x-show=step
          @click="step++"
          class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700 transition ml-auto"
        >
          Suivant <i class="fas fa-chevron-right ml-2"></i>
        </button>
        <button
          type="submit"
          x-show="step === 3"
          :disabled="loading"
          class="px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition ml-auto"
        >
          <i x-show="loading" class="fas fa-spinner fa-spin mr-2"></i>
          <i x-show="!loading" class="fas fa-check mr-2"></i>
          Soumettre la demande
      </button>
      </div>
    </form>

    <div class="mt-6 text-center">
      <p class="text-gray-500 dark:text-gray-400 text-sm">
