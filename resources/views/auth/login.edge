<!DOCTYPE html>
<html lang="{{ appLanguage || 'fr' }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="{{ csrfToken }}" />
    <title>Connexion - Gestion Éducative RDC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      :root {
        --auth-emblem-url: url('https://upload.wikimedia.org/wikipedia/commons/0/05/Coat_of_Arms_Democratic_Republic_of_Congo.png');
      }

      * {
        box-sizing: border-box;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: #111827;
        background: #ffffff;
      }

      .auth-header {
        height: calc(64px + 2rem);
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #ffffff;
      }

      .brand-logo {
        width: auto;
        max-width: min(calc(276px + 2rem), calc(52vw + 2rem));
        max-height: calc(52px + 2rem);
        padding: 6px 8px;
        object-fit: contain;
      }

      .auth-nav {
        display: flex;
        gap: 1rem;
      }

      .nav-button {
        padding: 0.65rem 1rem;
        border: 1px solid #111827;
        border-radius: 0.5rem;
        font-weight: 700;
        text-decoration: none;
      }

      .nav-button-primary {
        border-color: #1d4ed8;
        background: #1d4ed8;
        color: #ffffff;
      }

      .nav-button-outline {
        color: #111827;
      }

      main {
        position: relative;
        min-height: calc(100vh - (64px + 2rem));
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background:
          linear-gradient(135deg, rgba(37, 99, 235, 0.95), rgba(30, 64, 175, 0.98)),
          var(--auth-emblem-url) center / min(calc(520px + 25rem), 94vw) no-repeat;
      }

      main::before {
        position: absolute;
        inset: 0;
        content: '';
        background: var(--auth-emblem-url) center / min(calc(520px + 25rem), 94vw) no-repeat;
        opacity: 0.08;
        pointer-events: none;
      }

      .auth-panel {
        position: relative;
        width: min(430px, calc(100vw - 2rem));
        padding: 2rem;
        border-radius: 0.375rem;
        background: #1f2937;
        color: #ffffff;
        box-shadow: 0 24px 80px rgba(15, 23, 42, 0.35);
      }

      .auth-panel-header {
        text-align: center;
        margin-bottom: 1.75rem;
      }

      .auth-emblem {
        display: block;
        width: 86px;
        height: auto;
        margin: 0 auto 1rem;
      }

      h1 {
        margin: 0;
        font-size: 1.75rem;
        line-height: 1.2;
      }

      p {
        color: #cbd5e1;
      }

      label {
        display: block;
        margin: 1rem 0 0.45rem;
        color: #d1d5db;
        font-size: 0.875rem;
        font-weight: 700;
      }

      input {
        width: 100%;
        min-height: 44px;
        padding: 0.68rem 1rem;
        border: 1px solid rgba(148, 163, 184, 0.72);
        border-radius: 0.5rem;
        background: #f8fafc;
        color: #000000;
        font-size: 1rem;
        line-height: 1.25;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.06);
        outline: none;
        transition:
          border-color 0.18s ease,
          box-shadow 0.18s ease,
          background-color 0.18s ease;
        -webkit-text-fill-color: #000000;
      }

      input:hover {
        border-color: #94a3b8;
        background: #ffffff;
      }

      input:focus {
        border-color: #60a5fa;
        background: #ffffff;
        box-shadow:
          inset 0 1px 2px rgba(15, 23, 42, 0.06),
          0 0 0 3px rgba(96, 165, 250, 0.28);
      }

      input:-webkit-autofill,
      input:-webkit-autofill:hover,
      input:-webkit-autofill:focus {
        border-color: #60a5fa;
        box-shadow:
          inset 0 1px 2px rgba(15, 23, 42, 0.06),
          0 0 0 1000px #f8fafc inset;
        color: #000000;
        -webkit-text-fill-color: #000000;
      }

      .auth-panel input {
        padding-left: 1rem !important;
        padding-right: 1rem !important;
        text-indent: 0 !important;
      }

      .button {
        width: 100%;
        margin-top: 1.4rem;
        padding: 0.68rem 1rem;
        border: 0;
        border-radius: 0.45rem;
        background: #2563eb;
        color: #ffffff;
        font-weight: 800;
        cursor: pointer;
      }
    </style>
  </head>
  <body>
    <header class="auth-header">
      <a href="/">
        <img
          class="brand-logo"
          src="/images/logo-gouve-minepst.jpg"
          alt="Logo du Ministère de l'Enseignement Primaire, Secondaire et Technique"
        />
      </a>
      <nav class="auth-nav">
        <a href="/signup" class="nav-button nav-button-outline">Créer un compte</a>
        <a href="/login" class="nav-button nav-button-primary">Connexion</a>
      </nav>
    </header>

    <main>
      <section class="auth-panel">
        <div class="auth-panel-header">
          <img
            class="auth-emblem"
            src="https://upload.wikimedia.org/wikipedia/commons/0/05/Coat_of_Arms_Democratic_Republic_of_Congo.png"
            alt="Armoiries de la République démocratique du Congo"
          />
          <h1>Connexion</h1>
          <p>Accédez à votre espace selon votre rôle</p>
        </div>

        <form method="POST" action="/login">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

          <label for="email">Email</label>
          <input type="email" name="email" id="email" autocomplete="username" required />

          <label for="password">Mot de passe</label>
          <input type="password" name="password" id="password" autocomplete="current-password" required />

          <button type="submit" class="button">Se connecter</button>
        </form>
      </section>
    </main>
  </body>
</html>
