          <div class="p-4 hover:bg-gray-50 dark:hover:bg-gray-700">
            <div class="flex justify-between items-start">
              <div class="flex-1">
                <div class="flex items-center gap-3 flex-wrap">
                  <p class="font-medium text-gray-800 dark:text-white">
                    {{ message.senderName || message.receiverName }}
                  </p>
                  <span class="text-xs text-gray-400">{{ message.senderRole || message.receiverRole }}</span>
                  <span
                    class="px-2 py-0.5 rounded-full text-xs
              {{ message.type === 'official' ? 'bg-red-100 text-red-800' : 
                 (message.type === 'parent_teacher' ? 'bg-green-100 text-green-800' : 
                 (message.type === 'general' ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-800')) }}"
                  >
                    {{ message.type === 'official' ? 'Officiel' : 
                 (message.type === 'parent_teacher' ? 'Parent-Enseignant' : 
                 (message.type === 'general' ? 'Général' : 'Système')) }}
            </span>
                  @if(message.isIncoming)
                    <span class="text-xs text-blue-600">                      <i class="fas fa-arrow-down"></i>Reçu</span>
                  @else
                    <span class="text-xs text-green-600">                      <i class="fas fa-arrow-up"></i>Envoyé</span>
                  @endif
                </div>
                <p class="font-semibold text-gray-800 dark:text-white mt-1">
                  {{ message.subject }}
                </p>
                <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-1">
                  {{ message.preview }}
                </p>
                <div class="flex gap-3 mt-2 text-xs text-gray-400">
                  <span>                    <i class="fas fa-calendar mr-1"></i>Supprimé le {{ message.deletedAt }}</span>
                  <span>                    <i class="fas fa-clock mr-1"></i>Expire dans {{ message.daysUntilExpiry }} jours</span>
                </div>
              </div>
              <div class="flex gap-2">
                <button
                  onclick="restoreMessage('{{ message.id }}')"
                  class="text-green-600 hover:text-green-800"
