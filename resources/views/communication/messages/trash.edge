                >
                  <i class="fas fa-trash-restore"></i>
                </button>
                <button
                  onclick="deletePermanently('{{ message.id }}')"
                  class="text-red-500 hover:text-red-700"
                  title="Supprimer définitivement"
                >
                  <i class="fas fa-times-circle"></i>
                </button>
              </div>
            </div>
          </div>
          @else
          <div class="p-12 text-center text-gray-500">
            <i class="fas fa-trash-alt text-5xl mb-3 block"></i>
            <p>
              La corbeille est vide
            </p>
          </div>
        @end
      </div>

      @include('partials/pagination', { pagination: pagination, url: '/communication/messages/trash' })
    </div>

    <script>
      async function restoreMessage(messageId) {
        const res = await fetch(`/api/messages/${messageId}/restore`, {
          method: "POST",
          headers: {
            "X-CSRF-TOKEN": "{{ csrfToken }}"
          }
        });
        const data = await res.json();
        if (data.success) {
          location.reload();
        } else {
          alert("Erreur: " + data.message);
        }
      }

      async function deletePermanently(messageId) {
        if (confirm("Supprimer définitivement ce message ? Cette action est irréversible.")) {
          const res = await fetch(`/api/messages/${messageId}/permanent`, {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          if (data.success) {
            location.reload();
          } else {
            alert("Erreur: " + data.message);
          }
        }
      }

      async function emptyTrash() {
        if (confirm("Vider la corbeille ? Tous les messages seront définitivement supprimés.")) {
          const res = await fetch("/api/messages/empty-trash", {
            method: "DELETE",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          if (data.success) {
            location.reload();
          } else {
            alert("Erreur: " + data.message);
          }
        }
      }

      async function restoreAll() {
        if (confirm("Restaurer tous les messages de la corbeille ?")) {
          const res = await fetch("/api/messages/restore-all", {
            method: "POST",
            headers: {
              "X-CSRF-TOKEN": "{{ csrfToken }}"
            }
          });
          const data = await res.json();
          if (data.success) {
            location.reload();
          } else {
            alert("Erreur: " + data.message);
          }
        }
      }
    </script>
  @endsection
  
