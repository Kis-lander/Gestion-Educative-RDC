{{# layout('layouts/dashboard') }}

{{# section('title') }}Conversation - {{ contact.name }}{{# /section }}

{{# section('dashboardTitle') }}Conversation{{# /section }}
{{# section('dashboardSubtitle') }}Avec {{ contact.name }} ({{ contact.role }}){{# /section }}

{{# section('actions') }}
<div class="flex gap-2">
  <a href="/communication/messages/compose?reply_to={{ conversationId }}" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700">
    <i class="fas fa-reply mr-2"></i> Nouveau message
  </a>
  <button onclick="exportConversation()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">
    <i class="fas fa-download mr-2"></i> Exporter
  </button>
</div>
{{# /section }}

{{# section('content') }}
<div class="bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden flex flex-col h-[70vh]">
  <!-- En-tête conversation -->
  <div class="p-4 border-b dark:border-gray-700 bg-gray-50 dark:bg-gray-700">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">
          {{ contact.name.charAt(0) }}
        </div>
        <div>
          <h3 class="font-semibold">{{ contact.name }}</h3>
          <p class="text-sm text-gray-500">{{ contact.role }}</p>
        </div>
      </div>
      <div class="text-sm text-gray-400">
        {{ contact.status || 'En ligne' }}
      </div>
    </div>
  </div>
  
  <!-- Zone des messages -->
  <div id="conversationMessages" class="flex-1 p-4 overflow-y-auto">
    <div class="text-center py-12">
      <i class="fas fa-spinner fa-spin text-primary text-2xl"></i>
      <p class="text-gray-500 mt-2">Chargement des messages...</p>
    </div>
  </div>
  
  <!-- Zone de saisie -->
  <div class="p-4 border-t dark:border-gray-700">
    <form id="messageForm" onsubmit="event.preventDefault(); sendMessage()" class="flex gap-2">
      <input type="hidden" id="receiverId" value="{{ contact.id }}">
      <textarea id="messageContent" name="content" rows="2" 
                class="flex-1 px-3 py-2 border rounded-lg resize-none focus:ring-2 focus:ring-primary"
                placeholder="Écrivez votre message..."></textarea>
      <div class="flex flex-col gap-2">
        <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700">
          <i class="fas fa-paper-plane"></i>
        </button>
        <button type="button" onclick="document.getElementById('fileInput').click()" class="px-4 py-2 border rounded-lg hover:bg-gray-50">
          <i class="fas fa-paperclip"></i>
        </button>
        <input type="file" id="fileInput" class="hidden" accept=".pdf,.jpg,.png">
      </div>
    </form>
    <p class="text-xs text-gray-400 mt-2">
      <i class="fas fa-lock mr-1"></i> Messages privés et sécurisés
    </p>
  </div>
</div>

<script>
  let lastMessageId = 0
  let selectedFile = null
  
  async function loadMessages() {
    const receiverId = document.getElementById('receiverId').value
    const res = await fetch(`/api/messages/conversation/${receiverId}`)
    const data = await res.json()
    
    const container = document.getElementById('conversationMessages')
    
    if (data.messages && data.messages.length > 0) {
      const messagesHtml = data.messages.map(msg => `
        <div class="flex ${msg.isMine ? 'justify-end' : 'justify-start'} mb-4">
          <div class="max-w-[70%]">
            <div class="p-3 rounded-lg ${msg.isMine ? 'bg-primary text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-white'}">
              <p class="text-sm whitespace-pre-wrap">${escapeHtml(msg.content)}</p>
              ${msg.attachmentUrl ? `<a href="${msg.attachmentUrl}" target="_blank" class="text-xs underline mt-1 inline-block"><i class="fas fa-paperclip mr-1"></i> Fichier joint</a>` : ''}
            </div>
            <div class="flex items-center gap-2 mt-1 ${msg.isMine ? 'justify-end' : 'justify-start'}">
              <p class="text-xs text-gray-400">${msg.time}</p>
              ${msg.isMine && msg.read ? '<i class="fas fa-check-double text-xs text-primary"></i>' : ''}
            </div>
          </div>
        </div>
      `).join('')
      
      container.innerHTML = messagesHtml
      container.scrollTop = container.scrollHeight
      
      if (data.messages.length > 0) {
        lastMessageId = data.messages[data.messages.length - 1].id
      }
    } else {
      container.innerHTML = `
        <div class="text-center text-gray-500 py-12">
          <i class="fas fa-comment-dots text-4xl mb-3 block"></i>
          <p>Aucun message. Commencez la conversation !</p>
        </div>
      `
    }
  }
  
  document.getElementById('fileInput')?.addEventListener('change', function(e) {
    selectedFile = e.target.files[0]
    if (selectedFile) {
      sendMessageWithAttachment()
    }
  })
  
  async function sendMessage() {
    const content = document.getElementById('messageContent').value.trim()
    const receiverId = document.getElementById('receiverId').value
    
    if (!content) return
    
    const res = await fetch('/api/messages/send', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'X-CSRF-TOKEN': '{{ csrfToken }}'
      },
      body: JSON.stringify({ receiverId, content })
    })
    
    const data = await res.json()
    if (data.success) {
      document.getElementById('messageContent').value = ''
      loadMessages()
    } else {
      alert('Erreur: ' + data.message)
    }
  }
  
  async function sendMessageWithAttachment() {
    const content = document.getElementById('messageContent').value.trim() || "Voici un fichier joint"
    const receiverId = document.getElementById('receiverId').value
    
    const formData = new FormData()
    formData.append('receiverId', receiverId)
    formData.append('content', content)
    formData.append('attachment', selectedFile)
    
    const res = await fetch('/api/messages/send', {
      method: 'POST',
      headers: { 'X-CSRF-TOKEN': '{{ csrfToken }}' },
      body: formData
    })
    
    const data = await res.json()
    if (data.success) {
      document.getElementById('messageContent').value = ''
      selectedFile = null
      loadMessages()
    } else {
      alert('Erreur: ' + data.message)
    }
  }
  
  function escapeHtml(text) {
    const div = document.createElement('div')
    div.textContent = text
    return div.innerHTML
  }
  
  function exportConversation() {
    const receiverId = document.getElementById('receiverId').value
    window.location.href = `/api/messages/conversation/${receiverId}/export`
  }
  
  loadMessages()
  
  setInterval(() => {
    if (document.visibilityState === 'visible') {
      loadMessages()
    }
  }, 10000)
</script>
{{# /section }}

{{# /layout }}