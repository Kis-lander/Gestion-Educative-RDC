            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Province</label>
              <select name="province" class="w-full px-3 py-2 border rounded-lg">
                <option value="Kinshasa">
                  Kinshasa
                </option>
                <option value="Kongo Central">
                  Kongo Central
                </option>
                <option value="Haut-Katanga">
                  Haut-Katanga
                </option>
                <option value="Nord-Kivu">
                  Nord-Kivu
                </option>
                <option value="Sud-Kivu">
                  Sud-Kivu
                </option>
              </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Nombre maximum de participants</label>
                <input
                  type="number"
                  name="maxParticipants"
                  value="100"
                  min="1"
                  max="10000"
                  class="w-full px-3 py-2 border rounded-lg"
                />
              </div>
              <div>
                <label class="block text-gray-700 dark:text-gray-300 mb-2">Frais de participation</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">$</span>
                  <input
                    type="number"
                    name="participationFee"
                    step="0.01"
                    min="0"
