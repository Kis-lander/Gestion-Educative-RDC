            <div>
              <label class="block text-gray-700 dark:text-gray-300 mb-2">Type d'événement *</label>
              <select name="eventType" required class="w-full px-3 py-2 border rounded-lg">
                <option value="seminar">
                  Séminaire
                </option>
                <option value="workshop">
                  Atelier / Formation
                </option>
                <option value="competition">
                  Compétition académique
                </option>
