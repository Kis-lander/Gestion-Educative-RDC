                            (practice.category === 'technology' ? 'text-green-500' : 
                            (practice.category === 'management' ? 'text-purple-500' : 
                            (practice.category === 'discipline' ? 'text-red-500' : 
                            (practice.category === 'sports' ? 'text-orange-500' : 'text-yellow-500')))) }}"
                ></i>
              </div>
            </div>
          </div>

          <div class="pt-8 p-4">
            <div class="flex justify-between items-start">
              <div>
                <span
                  class="px-2 py-0.5 rounded-full text-xs 
            {{ practice.category === 'pedagogy' ? 'bg-blue-100 text-blue-800' : 
