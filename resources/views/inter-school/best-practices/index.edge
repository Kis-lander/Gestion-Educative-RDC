                  {{ practice.categoryLabel }}
          </span>
              </div>
              <div class="flex items-center gap-1 text-yellow-500">
                <i class="fas fa-star"></i>
                <span class="text-sm font-bold">{{ practice.rating || 0 }}</span>
              </div>
            </div>

            <h3 class="font-bold text-lg mt-2 line-clamp-1">
              {{ practice.title }}
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-2 line-clamp-2">
              {{ practice.description }}
            </p>

            <div class="flex justify-between items-center mt-3 text-xs text-gray-400">
              <div class="flex items-center gap-1">
                <i class="fas fa-school"></i>
                <span>{{ practice.schoolName }}</span>
              </div>
              <div class="flex items-center gap-1">
                <i class="fas fa-calendar"></i>
                <span>{{ practice.createdAt }}</span>
              </div>
