              >
                <i class="fas fa-eye mr-1"></i>Détails
        </a>
              <button
                onclick="likePractice('{{ practice.id }}')"
                class="px-3 py-1.5 border rounded-lg text-sm hover:bg-gray-50"
              >
                <i class="fas fa-heart text-red-500"></i>{{ practice.likes || 0 }}
        </button>
            </div>
          </div>
        </div>
        @else
        <div class="col-span-full text-center py-12 bg-white dark:bg-gray-800 rounded-xl">
