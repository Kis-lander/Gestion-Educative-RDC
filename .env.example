# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database
DB_CONNECTION=pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=gestion_educative_rdc
DATABASE_URL=

# Mail / OTP
# Use "console" locally; use "brevo_api" on Render, or "smtp" with a classic SMTP provider.
MAIL_MAILER=console
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@gestion-educative-rdc.cd
MAIL_FROM_NAME="Gestion Educative RDC"
MAIL_SECURE=false

# Brevo API
# Required on Render when MAIL_MAILER=brevo_api.
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3
BREVO_SENDER_EMAIL=${MAIL_FROM_ADDRESS}
BREVO_SENDER_NAME=${MAIL_FROM_NAME}

# OTP
OTP_CODE_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_PURPOSE=login

# OpenAI
OPENAI_API_KEY=
